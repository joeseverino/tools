#!/usr/bin/env bash
# brand <command> — render Joe's brand kits via the branding-engine
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" "" "$@"

CODE_HOME="${CODE_HOME:-$HOME/Documents/Code}"
BRAND_HOME="${BRAND_HOME:-$CODE_HOME/Assets/severino-brand}"
ENGINE_HOME="${ENGINE_HOME:-$CODE_HOME/Projects/branding-engine}"

describe_spec() {
    desc_tool "brand" "Render Joe's brand kits via the branding-engine."
    desc_inventory "Integrations" 150
    desc_synopsis "brand <command>"
    desc_effect read
    desc_para "Kits land in \$BRAND_HOME/kits. The engine lives in \$ENGINE_HOME and comes in as a dependency of the brand repo; see its README for all flags."
    desc_cmd build  -- "Rebuild every kit from brand/ + the social cards"
    desc_effect local_write
    desc_cmd kit    -- "Render a one-off kit into severino-brand/kits/<slug>"
    desc_effect local_write
    desc_pos slug              -- "Kit slug (output directory name)"
    desc_pos hex               -- "Primary brand color (hex, no leading #)"
    desc_pos initials          -- "Monogram initials"
    desc_pos wordmark +optional -- "Wordmark text"
    desc_opt --font FONT       -- "Font family"
    desc_opt --only LIST       -- "Comma-separated subset (e.g. mark,wordmark)"
    desc_opt --out DIR         -- "Output directory override"
    desc_cmd figure -- "Render a brand-themed graphic (cover, banner, diagram) from a JSON spec"
    desc_effect local_write
    desc_pos spec              -- "Path to a .figure.json spec (templates: title, flow, diamond, nodes)"
    desc_opt --out PNG         -- "Output path (defaults to <spec>.png)"
    desc_opt --tokens CSS      -- "Brand tokens.css (defaults to the primary kit's)"
    desc_opt --scale N         -- "Render scale multiplier (default 2)"
    desc_para "Spec format and template fields live in the engine README. Use this for designed graphics; use \`diagram\` for Mermaid flowcharts and sequence diagrams."
    desc_cmd status -- "Show engine + brand locations and git state"
    desc_effect read
    desc_env CODE_HOME   -- "Defaults to ~/Documents/Code"
    desc_env BRAND_HOME  -- "Defaults to \$CODE_HOME/Assets/severino-brand"
    desc_env ENGINE_HOME -- "Defaults to \$CODE_HOME/Projects/branding-engine"
}

require_brand() {
    [[ -d "$BRAND_HOME" ]] || die "error" "brand repo not found: $BRAND_HOME"
    [[ -f "$BRAND_HOME/package.json" ]] || die "error" "package.json not found in $BRAND_HOME"
    [[ -d "$BRAND_HOME/node_modules/branding-engine" ]] \
        || die "error" "engine not installed; run \`npm install\` in $BRAND_HOME"
}

cmd_build() {
    require_brand
    msg "$DIM" "brand" "$BRAND_HOME"
    (cd "$BRAND_HOME" && npm run -s build -- "$@")
}

cmd_kit() {
    if [[ "$#" -lt 3 ]]; then    # incomplete invocation → show the spec-derived help
        usage_command kit
        return 0
    fi
    require_brand
    msg "$DIM" "brand" "$BRAND_HOME"
    (cd "$BRAND_HOME" && npm run -s kit -- "$@")
}

cmd_figure() {
    if [[ "$#" -lt 1 ]]; then    # no spec → show the spec-derived help
        usage_command figure
        return 0
    fi
    local spec="$1"; shift
    [[ -f "$spec" ]] || die "error" "spec not found: $spec"
    local engine="$ENGINE_HOME/bin/cli.mjs"
    [[ -f "$engine" ]] || die "error" "branding-engine not found at $engine (set \$ENGINE_HOME)"

    # Default brand color to the primary kit's tokens unless the caller passes --tokens.
    # Prefer the joe-severino kit; fall back to the first kit that ships tokens.css.
    local has_tokens=0 a
    for a in "$@"; do [[ "$a" == "--tokens" ]] && has_tokens=1; done
    local default_tokens="$BRAND_HOME/kits/joe-severino/web/tokens.css"
    if [[ ! -f "$default_tokens" ]]; then
        default_tokens=$(find "$BRAND_HOME/kits" -mindepth 2 -maxdepth 3 -name tokens.css 2>/dev/null | sort | head -1)
    fi

    msg "$DIM" "engine" "$ENGINE_HOME"
    if (( ! has_tokens )) && [[ -n "$default_tokens" && -f "$default_tokens" ]]; then
        node "$engine" figure "$spec" --tokens "$default_tokens" "$@"
    else
        node "$engine" figure "$spec" "$@"
    fi
}

cmd_status() {
    require_brand
    echo
    msg "$RESET" "engine" "$ENGINE_HOME"
    msg "$RESET" "brand" "$BRAND_HOME"
    if [[ -d "$BRAND_HOME/.git" ]]; then
        local tree; tree=$(vault_tree "$BRAND_HOME")
        local color="$GREEN"; [[ "$tree" != "clean" ]] && color="$YELLOW"
        msg "$RESET" "git" "${color}${tree}${RESET}"
    fi
    if [[ -d "$BRAND_HOME/kits" ]]; then
        local n; n=$(find "$BRAND_HOME/kits" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' ')
        msg "$GREEN" "kits" "$n present"
    else
        msg "$YELLOW" "kits" "none built"
    fi
    echo
}

# All help + the machine surface render from the one spec via the shared
# intercept (main `-h`, `--describe`, focused `<cmd> -h`).
desc_help_intercept "$@"
case "${1:-}" in
    build)          shift; cmd_build "$@" ;;
    kit)            shift; cmd_kit "$@" ;;
    figure)         shift; cmd_figure "$@" ;;
    status)         shift; cmd_status "$@" ;;
    *)              die_unknown command "$1" ;;
esac
