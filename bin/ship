#!/usr/bin/env bash
# ship [options] [name] [-- paths...] — flush pending work into one PR per repo.
#
# Reads what to ship from `repos --json` (the read-side owner), then for each
# repo: commits, pushes a clean branch, and opens/updates one PR. Dry-run by
# default; single-repo by default; fleet only with --all. Holds up after a
# merge+branch-delete: it bases new work on a fresh branch off the default
# branch instead of pushing a zombie.
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" "" "$@"
# shellcheck source=lib/git.sh
source "$TOOLS_HOME/lib/git.sh"

# Echo the command that runs <repo path>'s own local gate, or nothing (return 1)
# if the repo declares none. First match wins: the tools repo's own `tools
# check`, then a scripts/check.sh, then a package.json check/test script run
# through the repo's package manager. This is what --check runs before pushing.
ship_gate_cmd() {
    local p="$1"
    [[ -x "$p/bin/tools" ]]      && { printf 'tools check --ci --no-bench'; return 0; }
    [[ -f "$p/scripts/check.sh" ]] && { printf 'bash scripts/check.sh'; return 0; }
    if [[ -f "$p/package.json" ]]; then
        local runner='npm run'
        [[ -f "$p/pnpm-lock.yaml" ]]                  && runner='pnpm run'
        [[ -f "$p/yarn.lock" ]]                       && runner='yarn'
        [[ -f "$p/bun.lockb" || -f "$p/bun.lock" ]]   && runner='bun run'
        local script
        script="$(node -e 'try{const s=(require(process.argv[1]).scripts)||{};process.stdout.write(s.check?"check":(s.test?"test":""))}catch(e){}' "$p/package.json" 2>/dev/null || true)"
        [[ -n "$script" ]] && { printf '%s %s' "$runner" "$script"; return 0; }
    fi
    return 1
}

describe_spec() {
    desc_tool "ship" "Commit, push, and PR pending work — one repo, or the whole fleet."
    desc_inventory "Workspace" 210
    desc_synopsis "ship [options] [name] [-- paths...]"
    desc_effect remote_write +network
    desc_opt --go         -- "Actually commit/push/PR (default is a dry-run preview)"
    desc_opt --all        -- "Required to act on more than one repo (a guard against accidental fleet ships)"
    desc_opt -m --message MSG -- "PR title + commit message (default: derived from changed paths)"
    desc_opt --body BODY  -- "PR body (default: a generated new/modified/removed file summary)"
    desc_opt --no-pr      -- "Commit and push only; do not open a PR"
    desc_opt --check      -- "Run the repo's own local gate (tools check --ci / scripts/check.sh / npm test) before pushing; skip the repo if it fails"
    desc_opt --watch      -- "After opening/updating the PR, poll 'gh pr checks' until CI is green or red"
    desc_opt --rebranch   -- "Recover a stale branch: replay its commits onto a fresh branch off origin/<base>, dropping any already merged (leaves the old branch untouched)"
    desc_pos name         -- "Only repos whose name contains NAME"
    desc_para "Preview with 'ship' or 'ship <name>'; execute with --go. A single repo needs no --all; a fleet ship requires --all so it can never happen by accident. Pass '-- path ...' to commit only those paths instead of everything. If you are on main (or a branch whose remote was merged and deleted) ship cuts a fresh 'ship/<timestamp>' branch off the default branch so main is never committed to and zombie branches are never pushed. The PR body defaults to a clean file summary; pass --body (or let an agent pass one) for a richer PR."
    desc_para "--check runs the repo's local gate before pushing so a failure is caught here, not after a CI round-trip; a repo that fails its gate is left unpushed. --watch then follows the PR's checks to green or red instead of you polling by hand. Together they close the write half of the loop: gate locally, ship, watch CI, then 'resync' once it merges."
    desc_para "ship is idempotent on an open PR, so iterating on one you review on GitHub is the same one command, not raw git. Re-run it after amending a commit and it re-pushes the branch with --force-with-lease and syncs the PR title to the (conventional) commit subject; the body is only rewritten when you pass --body, so a description you curated on GitHub is never clobbered."
}

desc_help_intercept "$@"

GO=0 ALL=0 NOPR=0 CHECK=0 WATCH=0 REBRANCH=0 BODY_SET=0 MSG="" BODY="" NAME=""
PATHS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --go)         GO=1; shift ;;
        --all)        ALL=1; shift ;;
        --no-pr)      NOPR=1; shift ;;
        --check)      CHECK=1; shift ;;
        --watch)      WATCH=1; shift ;;
        --rebranch)   REBRANCH=1; shift ;;
        -m|--message) MSG="${2:-}"; shift 2 ;;
        --body)       BODY="${2:-}"; BODY_SET=1; shift 2 ;;
        --)           shift; PATHS=("$@"); break ;;
        -*)           die_unknown option "$1" ;;
        *)            NAME="$1"; shift ;;
    esac
done

if (( GO )) && (( ! NOPR )) && [[ -n "$MSG" ]] && ! git_conventional_subject "$MSG"; then
    die "message" "PR title must be Conventional Commits / release-please friendly (example: feat: add repo dashboard)" 2
fi

include_clean_branch=0
[[ -n "$NAME" && "$NOPR" == "0" ]] && include_clean_branch=1
plan="$(repos --json ${NAME:+"$NAME"} 2>/dev/null | SHIP_INCLUDE_CLEAN_BRANCH="$include_clean_branch" node "$TOOLS_HOME/lib/ship/plan.mjs")"

if [[ -z "$plan" ]]; then
    header "ship" 0
    msg "$GREEN" "clean" "nothing to ship — every repo is committed and pushed"
    echo; exit 0
fi

count="$(printf '%s\n' "$plan" | grep -c . || true)"

# Safety: never act on more than one repo without --all.
if (( GO )) && (( count > 1 )) && (( ! ALL )); then
    header "ship" "$count"
    printf '%s\n' "$plan" | while IFS=$'\t' read -r n _; do msg "$DIM" "pending" "$n"; done
    echo
    die "refuse" "$count repos pending — name one (\`ship <name> --go\`) or pass --all" 2
fi

header "ship" "$count"
(( GO )) || msg "$YELLOW" "preview" "dry run — re-run with --go (single repo) or --all --go (fleet)"
echo

shipped=0
while IFS=$'\t' read -r name path branch uncommitted ahead has_remote; do
    [[ -n "$name" ]] || continue

    on_main=0
    [[ "$branch" == "main" || "$branch" == "master" || "$branch" == "-" ]] && on_main=1

    # preview line
    action=""
    (( uncommitted > 0 )) && action+="commit $uncommitted · "
    if (( on_main )); then action+="fresh branch · "; fi
    if (( has_remote )); then
        action+="push"; (( ahead > 0 )) && action+=" ↑$ahead"
    else
        action+="${RED}no remote — skip${RESET}"
    fi
    (( has_remote && ! NOPR )) && action+=" · PR"
    msg "$DIM" "$name" "$action"

    (( GO )) || continue
    (( has_remote )) || continue

    (
        cd "$path"
        git fetch -q origin --prune 2>/dev/null || true
        base="$(git_default_branch)"

        # lib/git.sh decides whether this branch is a safe home for new work and
        # otherwise starts clean off origin/<base> — so neither you nor an agent
        # ever has to remember to branch first. --rebranch recovers a stale
        # branch by replaying its commits onto a fresh one.
        if (( REBRANCH )); then
            if ! newb="$(git_rebranch "$base" ship)"; then
                printf '  %s%-10s%s %s\n' "$RED$BOLD" "skip" "$RESET" \
                    "$name: couldn't replay onto a fresh branch — a commit conflicts with already-merged work; rebase by hand: git rebase origin/$base"
                exit 0
            fi
            printf '  %s%-10s%s %s\n' "$DIM" "rebranch" "$RESET" "replayed onto $newb off origin/$base"
        else
            tb=0; git_target_branch "$base" ship >/dev/null || tb=$?
            if (( tb == GIT_TARGET_STALE )); then
                cur="$(git symbolic-ref --short -q HEAD 2>/dev/null || echo HEAD)"
                printf '  %s%-10s%s %s\n' "$YELLOW$BOLD" "stale" "$RESET" \
                    "$name: on '$cur' — behind origin/$base by $(git_behind_commits "$base") · $(git_unique_commits "$base") committed commit(s) · no PR"
                printf '  %s%-12s%s %s\n' "$DIM" "" "$RESET" "shipping here would re-inherit work that may already be merged."
                printf '  %s%-12s%s %s\n' "$DIM" "→ start" "$RESET" "start \"<slug>\"           (clean branch off origin/$base, then redo)"
                printf '  %s%-12s%s %s\n' "$DIM" "→ replay" "$RESET" "ship${NAME:+ $NAME} --rebranch --go   (carry these commits onto a fresh branch)"
                exit 0
            elif (( tb != GIT_TARGET_OK )); then
                printf '  %s%-10s%s %s\n' "$RED$BOLD" "skip" "$RESET" "$name: could not branch off origin/$base"
                exit 0
            fi
        fi

        if (( uncommitted > 0 )); then
            if (( ${#PATHS[@]} )); then git_commit "$MSG" "${PATHS[@]}" || true; else git_commit "$MSG" || true; fi
        fi

        # --check: run the repo's own gate before pushing, so a failure is
        # caught locally instead of after a CI round-trip.
        if (( CHECK )); then
            if gate="$(ship_gate_cmd "$path")"; then
                printf '  %s%-10s%s %s\n' "$DIM" "check" "$RESET" "$gate"
                if ! eval "$gate"; then
                    printf '  %s%-10s%s %s\n' "$RED$BOLD" "skip" "$RESET" "$name: local gate failed — not pushed"
                    exit 0
                fi
            else
                printf '  %s%-10s%s %s\n' "$DIM" "check" "$RESET" "$name: no local gate — pushing without one"
            fi
        fi

        # Plain push; if the branch was amended/rebased (non-fast-forward, the
        # "iterate on an open PR" case) re-push it safely with --force-with-lease,
        # which refuses if the remote moved under us. ship only ever pushes its
        # own feature branches, so forcing here is correct, not dangerous.
        git_push_current 2>/dev/null \
            || git push -q -u --force-with-lease origin HEAD 2>/dev/null \
            || { printf '  %s%-10s%s %s\n' "$RED$BOLD" "skip" "$RESET" "$name: push failed (check gh auth / remote)"; exit 0; }

        if (( ! NOPR )); then
            title="${MSG:-$(git log -1 --format='%s' 2>/dev/null || true)}"
            if ! git_conventional_subject "$title"; then
                printf '  %s%-10s%s %s\n' "$RED$BOLD" "skip" "$RESET" "$name: PR title is not release-please friendly: $title"
                printf '  %s%-10s%s %s\n' "$DIM" "hint" "$RESET" "rerun with -m 'feat: describe the change'"
                exit 2
            fi
            body="${BODY:-$(git_pr_body_summary "$base")}"
            # Existing PR: title is synced to the commit subject; body is only
            # rewritten when --body was passed (BODY_SET), so re-shipping never
            # clobbers a PR description you curated on GitHub.
            url="$(git_open_or_update_pr "$base" "$title" "$body" "$BODY_SET" || true)"
            printf '  %s%-10s%s %s\n' "$GREEN$BOLD" "PR" "$RESET" "${url:-(create failed — check gh auth)}"

            # --watch: follow CI to a terminal state instead of polling by hand.
            # A brand-new PR races CI registration, so wait until at least one
            # check exists before watching — otherwise `gh pr checks --watch`
            # exits instantly on "no checks" and reports a false result. Then
            # trust --watch's own exit code (it blocks until checks complete).
            if (( WATCH )); then
                printf '  %s%-10s%s %s\n' "$DIM" "watch" "$RESET" "polling gh pr checks…"
                tries=0
                until [[ -n "$("${GH_BIN:-gh}" pr checks 2>/dev/null)" ]] || (( tries >= 12 )); do
                    sleep 5; tries=$(( tries + 1 ))
                done
                if [[ -z "$("${GH_BIN:-gh}" pr checks 2>/dev/null)" ]]; then
                    printf '  %s%-10s%s %s\n' "$DIM" "watch" "$RESET" "$name: no checks registered — nothing to watch"
                elif "${GH_BIN:-gh}" pr checks --watch --interval 15 >/dev/null 2>&1; then
                    printf '  %s%-10s%s %s\n' "$GREEN$BOLD" "green" "$RESET" "$name: all checks passed"
                else
                    printf '  %s%-10s%s %s\n' "$RED$BOLD" "red" "$RESET" "$name: checks failed — see ${url:-the PR}"
                    # Land the failure in the terminal, not behind three gh commands.
                    git_print_failing_checks
                fi
            fi
        fi
    )
    shipped=$(( shipped + 1 ))
done <<< "$plan"

echo
if (( GO )); then
    msg "$GREEN" "shipped" "$shipped repo(s)"
    # Point at the next beat of the loop: the PR is open, land merges it once green.
    (( shipped > 0 )) && msg "$DIM" "next" "land${NAME:+ $NAME} once CI is green, then resync"
else
    n_hint="ship <name> --go"; (( ALL )) && n_hint="ship --all --go"
    msg "$DIM" "next" "$n_hint"
fi
echo
