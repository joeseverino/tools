#!/usr/bin/env bash
# resync [options] [name] — reconcile local repos with the remote after merging.
#
# The closing beat of the workspace loop (resync → work → ship → merge → resync).
# Your merges happen on GitHub (review the PR, merge, auto-delete the branch);
# nothing pushes that back to this Mac, so the local tree drifts — stale default
# branch, zombie branches, and you stranded on a branch that no longer exists on
# the remote. `resync` is the one command that reconciles it: fetch + prune,
# fast-forward the default branch, and drop local branches whose PR was merged
# and auto-deleted. lib/git.sh owns the mechanics (git_sync_clean); this is the
# fleet driver + report. It never deletes a branch with unique local commits and
# never touches a repo with uncommitted changes.
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" "" "$@"
# shellcheck source=lib/git.sh
source "$TOOLS_HOME/lib/git.sh"

describe_spec() {
    desc_tool "resync" "Reconcile local repos with the remote after merging PRs on GitHub."
    desc_inventory "Workspace" 220
    desc_synopsis "resync [options] [name]"
    desc_effect local_write +network
    desc_opt -n --dry-run -- "Show what would be reconciled; change nothing local"
    desc_pos name         -- "Only repos whose name contains NAME"
    desc_para "The closing beat of the workspace loop (resync → work → ship → merge → resync). For each clean repo with a remote: fetch + prune, fast-forward the default branch, and delete local branches whose upstream was merged and auto-deleted on GitHub. If you are stranded on such a branch (you merged the PR on GitHub and came back to the terminal still on it) resync steps you back onto the default branch first, then prunes it. It never deletes a branch that still has unique local commits — those are reported as 'kept (diverged)' so you can decide — and it never touches a repo with uncommitted changes. Defaults to the whole fleet; pass NAME to scope to one repo. --dry-run fetches (harmless) and reports the plan without changing any local branch or working tree."
}

desc_help_intercept "$@"

DRY=0 NAME=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        -n|--dry-run) DRY=1; shift ;;
        -*)           die_unknown option "$1" ;;
        *)            NAME="$1"; shift ;;
    esac
done

# Fleet state from its one owner (repos), projected to the fields resync needs:
# only git repos with a remote, as name<TAB>path<TAB>dirty-count.
plan="$(repos --json ${NAME:+"$NAME"} 2>/dev/null | node -e '
    let raw = "";
    process.stdin.on("data", (d) => (raw += d));
    process.stdin.on("end", () => {
        let j; try { j = JSON.parse(raw); } catch { process.exit(0); }
        for (const r of j.repos || []) {
            if (!r.git || !r.has_remote) continue;
            const dirty = (r.dirty || 0) + (r.untracked || 0);
            process.stdout.write([r.name, r.path, dirty].join("\t") + "\n");
        }
    });
')"

count="$(printf '%s\n' "$plan" | grep -c . || true)"
header "resync" "$count"
(( DRY )) && msg "$YELLOW" "preview" "dry run — nothing local will change"
echo

if [[ -z "$plan" ]]; then
    msg "$DIM" "none" "no git repos with a remote matched"
    echo; exit 0
fi

checked=0 dirty_left=0
while IFS=$'\t' read -r name path dirty; do
    [[ -n "$name" ]] || continue

    if (( dirty > 0 )); then
        msg "$YELLOW" "$name" "±$dirty uncommitted — left alone"
        dirty_left=$(( dirty_left + 1 ))
        continue
    fi

    (
        cd "$path"
        base="$(git_default_branch)"

        if (( DRY )); then
            git fetch -q origin --prune 2>/dev/null \
                || { msg "$RED" "$name" "fetch failed"; exit 0; }
            local_drop="" local_keep=""
            while read -r b; do
                [[ -n "$b" ]] || continue
                if [[ "$(git rev-list --count "origin/$base..$b" 2>/dev/null || echo 1)" == "0" ]]; then
                    local_drop+="${local_drop:+,}$b"
                else
                    local_keep+="${local_keep:+,}$b"
                fi
            done < <(git for-each-ref --format='%(refname:short) %(upstream:track)' refs/heads \
                        | awk -v base="$base" '/\[gone\]/ && $1 != base {print $1}')
            behind="$(git rev-list --count "$base..origin/$base" 2>/dev/null || echo 0)"
            parts=""
            [[ "$behind" != "0" ]]   && parts+="ff $base ↓$behind"
            [[ -n "$local_drop" ]]   && parts+="${parts:+ · }would drop: $local_drop"
            [[ -n "$local_keep" ]]   && parts+="${parts:+ · }would keep (diverged): $local_keep"
            msg "$DIM" "$name" "${parts:-already clean}"
            exit 0
        fi

        before_branch="$(git symbolic-ref --short -q HEAD 2>/dev/null || echo '-')"
        before_base="$(git rev-parse -q --verify "$base" 2>/dev/null || true)"
        before_n="$(git for-each-ref refs/heads | wc -l | tr -d ' ')"

        git_sync_clean "$base" || { msg "$RED" "$name" "fetch failed"; exit 0; }

        after_branch="$(git symbolic-ref --short -q HEAD 2>/dev/null || echo '-')"
        after_base="$(git rev-parse -q --verify "$base" 2>/dev/null || true)"
        after_n="$(git for-each-ref refs/heads | wc -l | tr -d ' ')"
        dropped=$(( before_n - after_n ))

        parts=""
        [[ "$before_branch" != "$after_branch" ]] && parts+="$before_branch → $after_branch"
        [[ -n "$before_base" && "$before_base" != "$after_base" ]] && parts+="${parts:+ · }ff $base"
        (( dropped > 0 )) && parts+="${parts:+ · }dropped $dropped"
        kept="$(git for-each-ref --format='%(refname:short) %(upstream:track)' refs/heads \
                    | awk -v base="$base" '/\[gone\]/ && $1 != base {print $1}' | paste -sd, - || true)"
        [[ -n "$kept" ]] && parts+="${parts:+ · }kept (diverged): $kept"

        if [[ -n "$parts" ]]; then
            msg "$GREEN" "$name" "$parts"
        else
            msg "$DIM" "$name" "already in sync"
        fi
    )
    checked=$(( checked + 1 ))
done <<< "$plan"

echo
msg "$DIM" "summary" "$checked reconciled · $dirty_left left dirty"
echo
