#!/usr/bin/env bash
# adguard — fetch the live AdGuard Home DNS rewrites and diff them against the
# vault cache. Drift-guard sibling of cf-dns / ts-acl; the show/diff/pull
# mechanics live in lib/drift.sh.
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" "adguard" "$@"
# shellcheck source=lib/drift.sh
source "$TOOLS_HOME/lib/drift.sh"

# New model: the cache is the `dns_rewrites` JSON file in the infra-dataset
# registry, read/written through the vault MCP. drift.sh keys off DRIFT_DATASET_ID.
DRIFT_DATASET_ID="${ADGUARD_DATASET_ID:-dns_rewrites}"

describe_spec() {
    desc_tool "adguard" "Fetch the live AdGuard Home DNS rewrites and diff them against the vault cache."
    desc_inventory "Drift guards" 110
    desc_synopsis "adguard <command>"
    desc_para "Rewrites are normalized to domain/answer, sorted by domain."
    drift_describe_commands
    desc_env ADGUARD_CREDS         -- "age-encrypted env holding ADGUARD_USER + ADGUARD_PASS"
    desc_env ADGUARD_URL           -- "AdGuard Home base URL (e.g. http://192.168.1.233:3001)"
    desc_env ADGUARD_DATASET_ID    -- "infra-dataset id for the cache (default dns_rewrites)"
}

# Decrypt the creds env and echo "user:pass" for curl basic auth. In memory only.
get_creds() {
    local creds user="" pass="" k v
    creds=$(drift_read_creds "${ADGUARD_CREDS}") || return 1
    while IFS='=' read -r k v; do
        case $k in
            ADGUARD_USER) user=$v ;;
            ADGUARD_PASS) pass=$v ;;
        esac
    done <<< "$creds"
    [[ -n $user && -n $pass ]] || die "error" "creds need ADGUARD_USER + ADGUARD_PASS" >&2
    printf '%s:%s' "$user" "$pass"
}

# Fetch the live DNS rewrites and reduce to the normalized, sorted set.
fetch_live() {
    local creds; creds=$(get_creds)
    curl -fsS -u "$creds" "${ADGUARD_URL%/}/control/rewrite/list" \
         -H "Accept: application/json" 2>/dev/null \
        | normalize \
        || die "error" "rewrite list fetch failed (is $ADGUARD_URL reachable?)"
}

# Normalize the rewrite array (stdin) to the diffable shape. Idempotent.
normalize() {
    jq -S 'map({domain, answer}) | sort_by(.domain, .answer)'
}

drift_main "$@"
