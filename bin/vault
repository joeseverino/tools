#!/usr/bin/env bash
# vault <command> — operations on the vault repo
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" vault "$@"
# shellcheck source=lib/git.sh
source "$TOOLS_HOME/lib/git.sh"

describe_spec() {
    desc_tool "vault" "Operations on the vault git repo."
    desc_inventory "Vault" 60
    desc_synopsis "vault <command>"
    desc_effect read
    desc_cmd sync   -- "Pull and push the vault repo"
    desc_effect remote_write +network
    desc_cmd status -- "Working tree, inbox count, remote sync state, and whether doc metadata changed since the last hq sync"
    desc_effect read +network
    desc_cmd inbox  -- "List notes currently in the inbox"
    desc_effect read
    desc_cmd daily  -- "Populate the daily note's generated brief region from brief --json (work to ship, review-due docs, stale backlog, drafts) as Obsidian callouts — idempotent; never touches your free-capture area below the region"
    desc_effect vault_write
    desc_opt --date DATE -- "Daily note date (YYYY-MM-DD; default today)"
    desc_env NOTES_HOME -- "Read from ~/.zshrc; resolves VAULT"
    desc_env VAULT      -- "Per-invocation override for the vault path"
    desc_env INBOX_DIR  -- "Per-invocation override for the inbox folder"
}

require_vault() {
    [[ -d "$VAULT" ]]      || die "error" "vault not found: $VAULT"
    [[ -d "$VAULT/.git" ]] || die "error" "not a git repo: $VAULT"
}

vault_sync() {
    require_vault
    cd "$VAULT"
    echo

    # Rides lib/git.sh: pull --rebase then push are owned by the engine
    # (git_pull_push). Git's own errors still surface on stderr on failure.
    if git_pull_push; then
        msg "$GREEN" "synced" "pull --rebase + push"
    else
        msg "$RED" "failed" "sync — see git output above"
        echo; exit 1
    fi

    echo
}

vault_status() {
    require_vault
    echo

    local tree remote n
    tree=$(vault_tree   "$VAULT")
    n=$(inbox_count     "$INBOX_DIR")
    remote=$(vault_remote "$VAULT")

    if [[ "$tree" == "clean" ]]; then
        msg "$GREEN"  "tree" "clean"
    else
        msg "$YELLOW" "tree" "$tree"
    fi

    if (( n > 0 )); then
        msg "$YELLOW" "inbox" "$n pending note$([[ $n -eq 1 ]] || echo s)"
    else
        msg "$GREEN"  "inbox" "empty"
    fi

    if [[ "$remote" == "in sync" ]]; then
        msg "$GREEN"  "remote" "in sync"
    else
        msg "$YELLOW" "remote" "$remote"
    fi

    # Vault → HQ freshness: exact (manifest hash), so prose-only edits never
    # flag. `skip` (no MCP, state from another vault) prints nothing.
    local hq_state
    hq_state="$(hq_sync_freshness "$VAULT")"
    case "$hq_state" in
        never)  msg "$YELLOW" "hq" "never synced — run \`hq sync\`" ;;
        skip)   ;;
        fresh*) msg "$GREEN"  "hq" "in sync (last sync ${hq_state#fresh })" ;;
        stale*) msg "$YELLOW" "hq" "doc metadata changed since last sync (${hq_state#stale }) — run \`hq sync\`" ;;
    esac

    echo
}

vault_inbox() {
    [[ -d "$INBOX_DIR" ]] || die "error" "inbox not found: $INBOX_DIR"
    echo

    local count=0
    local f
    for f in "$INBOX_DIR"/*.md; do
        [[ -f "$f" ]] || continue
        printf '  %s\n' "$(basename "$f" .md)"
        count=$((count+1))
    done

    if (( count == 0 )); then
        msg "$GREEN" "inbox" "empty"
    else
        echo
        printf '  %s%d note%s%s\n' "$BOLD" "$count" "$([ "$count" -eq 1 ] || echo s)" "$RESET"
    fi
    echo
}

# Populate the daily note's region with a log of what you DID that day — commits
# across the fleet + work shipped. A daily note is retrospective (the cockpit
# shows pending work; this shows the record). The chain keeps owners intact:
# repos --json owns the repo list, backlog --json --all owns the task ledger →
# daily-gather.mjs folds each repo's commit log for the date + the day's closures
# → daily.mjs renders → svmc daily-write writes the marked region atomically.
vault_daily() {
    local date=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --date) date="${2:-}"; shift 2 ;;
            -*)     die_unknown flag "$1" daily ;;
            *)      die_unknown argument "$1" daily ;;
        esac
    done
    echo

    local day repos_json board activity block result
    day="${date:-$(date +%F)}"
    repos_json="$(repos --json 2>/dev/null)"      || die "error" "repos --json failed"
    board="$(backlog --json --all 2>/dev/null)"   || board='{"tasks":[]}'
    activity="$(printf '{"date":"%s","repos":%s,"board":%s}' "$day" "$repos_json" "$board" \
        | node "$TOOLS_HOME/lib/brief/daily-gather.mjs" "$day")" \
        || die "error" "gathering the day's activity failed"
    block="$(printf '%s' "$activity" | node "$TOOLS_HOME/lib/brief/daily.mjs" "$day")" \
        || die "error" "rendering the daily block failed"

    local write_args=()
    [[ -n "$date" ]] && write_args=(--date "$date")
    result="$(printf '%s' "$block" | svmc daily-write ${write_args[@]+"${write_args[@]}"})" \
        || die "error" "daily-write failed (is the MCP installed? site reinstall-mcp)"

    # Parse the MCP's {ok,...} envelope — node is the JSON tool (repo convention).
    local line kind detail state
    # shellcheck disable=SC2016  # the node script is literal — no shell expansion
    line="$(printf '%s' "$result" | node -e '
let s="";process.stdin.on("data",c=>s+=c);process.stdin.on("end",()=>{
  let j={};try{j=JSON.parse(s)}catch{};
  if(j.ok){process.stdout.write(`ok\t${j.wrote||""}\t${j.created?"created":"updated"}`)}
  else{process.stdout.write(`err\t${j.error||"failed"}`)}});')"
    IFS=$'\t' read -r kind detail state <<<"$line"
    if [[ "$kind" == "ok" ]]; then
        msg "$GREEN" "daily" "$state brief region → $detail"
    else
        die "error" "daily-write: $detail"
    fi
    echo
}

# All help + the machine surface render from the one spec via the shared
# intercept (main `-h`, `--describe`, focused `<cmd> -h`).
desc_help_intercept "$@"
case "${1:-}" in
    sync)              shift; vault_sync   "$@" ;;
    status)            shift; vault_status "$@" ;;
    inbox)             shift; vault_inbox  "$@" ;;
    daily)             shift; vault_daily  "$@" ;;
    *)                 die_unknown command "$1" ;;
esac
