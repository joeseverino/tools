#!/usr/bin/env bash
# brief [options] — one emit-once snapshot of the whole workspace.
# Aggregates the deterministic emitters (repos, the MCP's vault brief, the MCP's
# writeup list) into one digest, so an agent orients in a single cheap read
# instead of running a dozen git/find/cat commands and inferring. `--json` is
# the machine surface. Vault facts come through the MCP — its one owner.
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" "" "$@"

describe_spec() {
    desc_tool "brief" "One emit-once snapshot of repos, vault, and writeups."
    desc_inventory "Workspace" 200
    desc_synopsis "brief [options]"
    # Reads only, but --prs reaches GitHub over the network.
    desc_effect read +network
    desc_opt --json     -- "Machine-readable digest (one JSON object)"
    desc_opt --prs      -- "Include open GitHub PRs per repo (slower; runs gh)"
    desc_opt --days DAYS -- "Vault recent-changes window in days (default 7)"
    desc_para "Pure aggregator: it never re-implements a fact. Repo state comes from 'repos', and every vault fact (recent changes, docs to review, inbox) comes from 'severino-vault-mcp brief' and 'list-writeups' — the vault's one owner. Run 'brief' to orient at the start of a session, 'brief --json' to consume the whole workspace state in a single parse."
}

desc_help_intercept "$@"

JSON=0 PRS=0 DAYS=7
while [[ $# -gt 0 ]]; do
    case "$1" in
        --json) JSON=1; shift ;;
        --prs)  PRS=1; shift ;;
        --days) DAYS="${2:-7}"; shift 2 ;;
        -*)     die_unknown option "$1" ;;
        *)      die_unknown argument "$1" ;;
    esac
done

# Each fact from its one owner; a failed emitter degrades to null, never aborts.
repos_json="$(repos --json 2>/dev/null || echo 'null')"
vault_json="$(severino-vault-mcp brief --days "$DAYS" 2>/dev/null || echo 'null')"
writeups_json="$(severino-vault-mcp list-writeups --filter all 2>/dev/null || echo 'null')"

prs_json='null'
if (( PRS )); then
    items=()
    while IFS=$'\t' read -r rname rpath; do
        [[ -n "$rpath" ]] || continue
        list="$(cd "$rpath" && gh pr list --json number,title,state -L 10 2>/dev/null || echo '[]')"
        [[ "$list" == "[]" || -z "$list" ]] && continue
        items+=("{\"repo\":\"$rname\",\"prs\":$list}")
    done < <(printf '%s' "$repos_json" | node "$TOOLS_HOME/lib/brief/remotes.mjs")
    prs_json="[$(IFS=,; echo "${items[*]:-}")]"
fi

mode="human"; (( JSON )) && mode="json"
printf '{"repos":%s,"vault":%s,"writeups":%s,"prs":%s}' \
    "$repos_json" "$vault_json" "$writeups_json" "$prs_json" \
    | node "$TOOLS_HOME/lib/brief/render.mjs" "$mode"
