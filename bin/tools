#!/usr/bin/env bash
# tools <command> — umbrella command for the personal CLI tools
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" ""

# tools' subcommands read every config without having one of its own. Each
# config asserts its layout env var with ${VAR:?…}, which in bash kills the
# WHOLE shell from a sourced file (no, `|| true` doesn't catch it). We gate
# each source on the relevant env var so `doctor` can still report what's
# missing instead of dying at startup.
# shellcheck source=config/vault.sh
[[ -n "${NOTES_HOME-}"   ]] && source "$TOOLS_HOME/config/vault.sh"
# shellcheck source=config/backup.sh.example
[[ -n "${BACKUPS_HOME-}" ]] && source "$TOOLS_HOME/config/backup.sh"
# shellcheck source=config/crypt.sh
[[ -n "${KEYS_HOME-}"    ]] && source "$TOOLS_HOME/config/crypt.sh"
source "$TOOLS_HOME/lib/key.sh"
source "$TOOLS_HOME/lib/doctor.sh"

TOOL_NAMES=()
for file in "$TOOLS_HOME/bin"/*; do
    if [[ -f "$file" && -x "$file" ]]; then
        TOOL_NAMES+=("$(basename "$file")")
    fi
done
INSTALL_DIR="${TOOLS_INSTALL_DIR:-$HOME/.local/bin}"

usage() {
    cat <<EOF
Usage: tools <command>

Commands:
  status        One-screen health check across vault, inbox, backup, keys
  doctor        Verify environment, deps, and installed symlinks.
                --all adds every system's own gate (hq doctor, hq schema
                --check, site doctor) — the one cross-system health rollup.
                --live also runs the drift guards (cf-dns/adguard/ts-acl)
  check         Run the full CI suite locally: lint, tests, bench
  new <name>    Scaffold a new tool in bin/ with the house conventions
  install       Create symlinks in $INSTALL_DIR for every tool
  key           Cache / forget / test the age key passphrase in Keychain
  watch         Manage the optional launchd auto-sync agent (off by default)
  -h, --help    Show this help

status and doctor accept --json for machine-readable output.

Environment:
  TOOLS_HOME            Read from ~/.zshrc; root of this repo
  TOOLS_INSTALL_DIR     Override install target (default: ~/.local/bin)
EOF
}

# ---------- status ----------

cmd_status() {
    local json=0
    [[ "${1:-}" == "--json" ]] && json=1

    # Gather every value first; render text or JSON from the same facts.
    local vault_ok=0 tree="" remote=""
    if [[ -d "${VAULT:-}" && -d "${VAULT:-}/.git" ]]; then
        vault_ok=1
        tree=$(vault_tree   "$VAULT")
        remote=$(vault_remote "$VAULT")
    fi

    local inbox_ok=0 pending=0
    if [[ -d "${INBOX_DIR:-}" ]]; then
        inbox_ok=1
        pending=$(inbox_count "$INBOX_DIR")
    fi

    local backup_ok=0 backup_repo=0 last_msg="" last_when=""
    if [[ -n "${BACKUPS_HOME:-}" ]]; then
        backup_ok=1
        if [[ -d "$BACKUPS_HOME/.git" ]]; then
            backup_repo=1
            last_msg=$(git -C "$BACKUPS_HOME" log -1 --pretty='%s' 2>/dev/null || echo "")
            last_when=$(git -C "$BACKUPS_HOME" log -1 --pretty='%cr' 2>/dev/null || echo "")
        fi
    fi

    local pub_ok=0 key_ok=0
    [[ -f "${AGE_PUBKEY:-}" ]] && pub_ok=1
    [[ -f "${AGE_KEY:-}"    ]] && key_ok=1

    if (( json )); then
        printf '{"vault":{"ok":%s,"tree":"%s","remote":"%s","path":"%s"},' \
            "$(json_bool "$vault_ok")" "$(json_escape "$tree")" \
            "$(json_escape "$remote")" "$(json_escape "${VAULT:-}")"
        printf '"inbox":{"ok":%s,"pending":%d},' "$(json_bool "$inbox_ok")" "$pending"
        printf '"backup":{"ok":%s,"git_repo":%s,"last_commit":"%s","last_commit_when":"%s"},' \
            "$(json_bool "$((backup_ok && backup_repo))")" "$(json_bool "$backup_repo")" \
            "$(json_escape "$last_msg")" "$(json_escape "$last_when")"
        printf '"keys":{"ok":%s,"pub":%s,"private":%s}}\n' \
            "$(json_bool "$((pub_ok && key_ok))")" "$(json_bool "$pub_ok")" "$(json_bool "$key_ok")"
        return 0
    fi

    echo

    if (( vault_ok )); then
        local tree_color="$GREEN" remote_color="$GREEN"
        [[ "$tree"   != "clean"   ]] && tree_color="$YELLOW"
        [[ "$remote" != "in sync" ]] && remote_color="$YELLOW"
        msg "$RESET" "vault" "${tree_color}${tree}${RESET}, ${remote_color}${remote}${RESET} ${DIM}($VAULT)${RESET}"
    else
        msg "$RED" "vault" "not a git repo or VAULT not set"
    fi

    if (( inbox_ok )); then
        if (( pending > 0 )); then
            msg "$YELLOW" "inbox" "$pending pending note$([[ $pending -eq 1 ]] || echo s)"
        else
            msg "$GREEN" "inbox" "empty"
        fi
    else
        msg "$RED" "inbox" "INBOX_DIR not set or missing"
    fi

    if (( backup_repo )); then
        if [[ -n "$last_msg" ]]; then
            msg "$GREEN" "backup" "last commit ${DIM}${last_when}${RESET} — $last_msg"
        else
            msg "$YELLOW" "backup" "no commits yet"
        fi
    elif (( backup_ok )); then
        msg "$YELLOW" "backup" "$BACKUPS_HOME ${DIM}(not a git repo)${RESET}"
    else
        msg "$RED" "backup" "BACKUPS_HOME not set"
    fi

    if (( pub_ok && key_ok )); then
        msg "$GREEN" "keys" "pub + private present"
    else
        local detail=""
        (( pub_ok )) || detail+="missing pub "
        (( key_ok )) || detail+="missing private"
        msg "$RED" "keys" "$detail"
    fi

    echo
}

# ---------- doctor ----------
# check/check_warn/gate/doctor_finish live in lib/doctor.sh (shared plumbing
# + the cross-system gate registry behind --all).

cmd_doctor() {
    local fail=0 run_all=0 run_live=0
    DOCTOR_JSON=0
    DOCTOR_CHECKS=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) DOCTOR_JSON=1 ;;
            --all)  run_all=1 ;;
            --live) run_all=1; run_live=1 ;;
            -h|--help)
                cat <<EOF
Usage: tools doctor [--all] [--live] [--json]

Verify environment, deps, completions, and installed symlinks.

  --all     The cross-system health rollup: also run every system's own
            gate — hq doctor (frontmatter validity + vault→HQ sync
            freshness), hq schema --check (3-way contract parity), and
            site doctor (seams, MCP install drift, security, contrast,
            parity, types, audits). Exit 1 if any gate fails.
  --live    Implies --all; additionally run the drift guards
            (cf-dns / adguard / ts-acl diff) — live API reads that need
            network and the age key.
  --json    Machine-readable output (one object, "checks" array).
EOF
                return 0 ;;
            *) die "usage" "unknown option: $1 (try -h)" 2 ;;
        esac
        shift
    done
    (( DOCTOR_JSON )) || echo

    # Layout env vars
    for var in TOOLS_HOME KEYS_HOME NOTES_HOME BACKUPS_HOME; do
        if [[ -n "${!var:-}" ]]; then
            check "\$$var" 1 "${!var}" || fail=1
        else
            check "\$$var" 0 "not exported in current shell" || fail=1
        fi
    done

    # Resolved paths. Plain if/else — the [[ ]] && a || b shorthand drops
    # commands inside the `b` branch under `set -e`, so the function would
    # exit early on the first missing path.
    check_path() {
        local kind="$1" label="$2" path="${3:-}"
        local ok=0
        if [[ -n "$path" ]]; then
            [[ "$kind" == "d" && -d "$path" ]] && ok=1
            [[ "$kind" == "f" && -f "$path" ]] && ok=1
        fi
        if (( ok )); then
            check "$label" 1 "$path" || fail=1
        else
            check "$label" 0 "${path:-unset}" || fail=1
        fi
    }
    check_path d "VAULT directory" "${VAULT:-}"
    check_path d "INBOX_DIR"       "${INBOX_DIR:-}"
    check_path f "AGE_PUBKEY"      "${AGE_PUBKEY:-}"
    check_path f "AGE_KEY"         "${AGE_KEY:-}"

    # External deps
    for cmd in age git rsync; do
        if command -v "$cmd" >/dev/null; then
            check "$cmd" 1 "$(command -v "$cmd")" || fail=1
        else
            check "$cmd" 0 "not installed" || fail=1
        fi
    done

    # Node toolchain — optional: only doc-to-pdf / site manage / site compare
    # need it, so a missing node warns instead of failing.
    if command -v node >/dev/null; then
        check "node" 1 "$(command -v node)"
        if [[ -f "$TOOLS_HOME/package.json" && ! -d "$TOOLS_HOME/node_modules" ]]; then
            check_warn "node_modules" "missing — run: npm ci (needed by doc-to-pdf)"
        fi
    else
        check_warn "node" "not installed — doc-to-pdf and site manage/compare need it"
    fi

    # Completions drift — every tool in bin/ should be on the #compdef line.
    local compdef missing_comp=""
    compdef="$(head -1 "$TOOLS_HOME/completions/_tools-suite" 2>/dev/null || echo "")"
    for name in "${TOOL_NAMES[@]}"; do
        [[ " ${compdef#\#compdef } " == *" $name "* ]] || missing_comp+="$name "
    done
    if [[ -z "$missing_comp" ]]; then
        check "completions cover bin/" 1 "${#TOOL_NAMES[@]} tools"
    else
        check "completions cover bin/" 0 "missing from #compdef: ${missing_comp% }" || fail=1
    fi

    # Symlinks in install dir (top-level tools + lib helpers)
    for name in "${TOOL_NAMES[@]}"; do
        local link="$INSTALL_DIR/$name"
        if [[ -L "$link" ]]; then
            local target
            target="$(readlink "$link")"
            if [[ "$target" == "$TOOLS_HOME/bin/$name" ]]; then
                check "$name symlink" 1 "$link"
            else
                check "$name symlink" 0 "points to $target, expected $TOOLS_HOME/bin/$name"
                fail=1
            fi
        else
            check "$name symlink" 0 "not in $INSTALL_DIR (run: tools install)"
            fail=1
        fi
    done

    # The cross-system rollup: each system's own gate, from the registry in
    # lib/doctor.sh. Exit codes are the contract; detail stays in each tool.
    if (( run_all )); then
        if (( ! DOCTOR_JSON )); then
            echo
            printf '  %ssystems%s\n' "$BOLD" "$RESET"
        fi
        doctor_gates || fail=1
        if (( run_live )); then
            doctor_live_gates || fail=1
        else
            check_warn "drift guards" "skipped — live API reads (network + age key); rerun with --live"
        fi
    fi

    doctor_finish "$fail"
}

# ---------- install ----------

cmd_install() {
    mkdir -p "$INSTALL_DIR"
    echo
    local created=0 updated=0 skipped=0
    for name in "${TOOL_NAMES[@]}"; do
        local src="$TOOLS_HOME/bin/$name" dst="$INSTALL_DIR/$name"
        [[ -x "$src" ]] || { msg "$RED" "skipped" "$name ${DIM}(not executable at $src)${RESET}"; skipped=$((skipped+1)); continue; }
        if [[ -L "$dst" ]]; then
            local current
            current="$(readlink "$dst")"
            if [[ "$current" == "$src" ]]; then
                msg "$DIM" "ok" "$name ${DIM}(already linked)${RESET}"
                skipped=$((skipped+1))
                continue
            fi
            ln -sf "$src" "$dst"
            msg "$YELLOW" "updated" "$name ${DIM}→ $src${RESET}"
            updated=$((updated+1))
        elif [[ -e "$dst" ]]; then
            msg "$RED" "skipped" "$name ${DIM}($dst exists, not a symlink)${RESET}"
            skipped=$((skipped+1))
        else
            ln -s "$src" "$dst"
            msg "$GREEN" "linked" "$name ${DIM}→ $src${RESET}"
            created=$((created+1))
        fi
    done
    echo
    printf '  %sinstall%s    %d created, %d updated, %d skipped\n\n' \
        "$BOLD" "$RESET" "$created" "$updated" "$skipped"
    case ":$PATH:" in
        *":$INSTALL_DIR:"*) ;;
        *) printf "  %snote%s       %s is not on \$PATH — add it in ~/.zshrc\n\n" \
            "$BOLD$YELLOW" "$RESET" "$INSTALL_DIR" ;;
    esac
}

# ---------- check (the CI suite, runnable locally) ----------
# CI calls `tools check` so the definition of "passing" lives in exactly
# one place. Tools are discovered by shebang — adding a file to bin/ adds
# it to every check automatically.

cmd_check() {
    local run_bench=1 fail=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-bench) run_bench=0; shift ;;
            -h|--help)
                cat <<EOF
Usage: tools check [--no-bench]

Run everything CI runs, locally: bash -n / zsh -n / node --check by
shebang over bin/, shellcheck over the tracked shell sources, the bats
test suite, and the bench assertions. Exit 1 if anything fails.

  --no-bench    Skip the bench scripts (the slowest step)
EOF
                return 0 ;;
            *) die "usage" "unknown option: $1 (try -h)" 2 ;;
        esac
    done

    cd "$TOOLS_HOME"
    echo
    local f n err step_ok

    # bash -n
    step_ok=1; n=0
    for f in bin/* bench/*.sh; do
        shebang_has bash "$f" || continue
        n=$((n+1))
        if ! err=$(bash -n "$f" 2>&1); then
            msg "$RED" "fail" "bash -n $f"
            printf '%s\n' "$err" | sed 's/^/    /'
            step_ok=0
        fi
    done
    check "bash -n" "$step_ok" "$n scripts" || fail=1

    # zsh -n
    step_ok=1; n=0
    for f in bin/*; do
        shebang_has zsh "$f" || continue
        n=$((n+1))
        if ! err=$(zsh -n "$f" 2>&1); then
            msg "$RED" "fail" "zsh -n $f"
            printf '%s\n' "$err" | sed 's/^/    /'
            step_ok=0
        fi
    done
    check "zsh -n" "$step_ok" "$n scripts" || fail=1

    # node --check (lib modules by extension, bin launchers by shebang —
    # stdin keeps the parse mode independent of node's syntax detection)
    if command -v node >/dev/null; then
        step_ok=1; n=0
        for f in lib/*/*.mjs; do
            [[ -e "$f" ]] || continue
            n=$((n+1))
            if ! err=$(node --check "$f" 2>&1); then
                msg "$RED" "fail" "node --check $f"
                printf '%s\n' "$err" | sed 's/^/    /'
                step_ok=0
            fi
        done
        for f in bin/*; do
            shebang_has node "$f" || continue
            n=$((n+1))
            if ! err=$(node --input-type=module --check < "$f" 2>&1); then
                msg "$RED" "fail" "node --check $f"
                printf '%s\n' "$err" | sed 's/^/    /'
                step_ok=0
            fi
        done
        check "node --check" "$step_ok" "$n scripts" || fail=1
    else
        check "node --check" 0 "node not installed" || fail=1
    fi

    # Lint tracked shell sources only; local config/*.sh copies are
    # user-specific and would make the check non-reproducible.
    if command -v shellcheck >/dev/null; then
        local sc_targets=()
        for f in bin/* bench/*.sh; do
            shebang_has bash "$f" && sc_targets+=("$f")
        done
        # lib/*.sh and config/*.sh have no shebang to route on, so discover them
        # via git: tracked or new-but-unignored sources are linted, while
        # gitignored user-local config copies (backup.sh, site.sh, ...) are not.
        # New files (a new lib helper or config/<tool>.sh) are covered
        # automatically — no hand-editing here.
        while IFS= read -r f; do
            sc_targets+=("$f")
        done < <(git ls-files --cached --others --exclude-standard \
                     'lib/*.sh' 'config/*.sh' 'config/*.sh.example')
        if err=$(shellcheck -x "${sc_targets[@]}" 2>&1); then
            check "shellcheck" 1 "${#sc_targets[@]} files"
        else
            printf '%s\n' "$err" | sed 's/^/    /'
            check "shellcheck" 0 "findings above" || fail=1
        fi
    else
        check "shellcheck" 0 "not installed (brew install shellcheck)" || fail=1
    fi

    # bats tests
    if [[ -d tests ]]; then
        if command -v bats >/dev/null; then
            if err=$(bats tests 2>&1); then
                check "bats tests" 1 "$(printf '%s\n' "$err" | grep -c '^ok') passed"
            else
                printf '%s\n' "$err" | sed 's/^/    /'
                check "bats tests" 0 "failures above" || fail=1
            fi
        else
            check "bats tests" 0 "bats not installed (brew install bats-core)" || fail=1
        fi
    fi

    # bench — each script asserts its own claim and exits nonzero on regression
    if (( run_bench )); then
        for f in bench/*.sh; do
            if err=$("./$f" 2>&1); then
                check "bench ${f##*/}" 1
            else
                printf '%s\n' "$err" | tail -20 | sed 's/^/    /'
                check "bench ${f##*/}" 0 "output above" || fail=1
            fi
        done
    fi

    echo
    if (( fail )); then
        printf '  %scheck%s     one or more checks failed\n\n' "$BOLD$RED" "$RESET"
        return 1
    fi
    printf '  %scheck%s     all checks passed\n\n' "$BOLD$GREEN" "$RESET"
}

# ---------- new (scaffold a tool with the house conventions) ----------

cmd_new() {
    local name="" drift=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                cat <<EOF
Usage: tools new <name> [--drift]

Scaffold bin/<name>: bash + set -euo pipefail, the lib/init.sh sourcing
line, a usage() block, and arg parsing wired to die/msg. Prints the
follow-ups (completions, install) when done.

  --drift   Scaffold a drift-guard tool instead (the ts-acl / cf-dns shape):
            show / diff / pull, with get_token / fetch_live / normalize /
            vault_block already wired, plus a config/<name>.sh template.
            Fill in the TODOs (endpoint, creds key, jq projection).
EOF
                return 0 ;;
            --drift)    drift=1; shift ;;
            -*)         die "usage" "unknown option: $1 (try -h)" 2 ;;
            *)          name="$1"; shift ;;
        esac
    done
    [[ -n "$name" ]] || die "usage" "tools new <name> [--drift] (try -h)" 2
    [[ "$name" =~ ^[a-z][a-z0-9-]*$ ]] || die "usage" "name must be lowercase letters, digits, dashes" 2
    local target="$TOOLS_HOME/bin/$name"
    [[ -e "$target" ]] && die "error" "bin/$name already exists"
    # Env-var prefix for config vars: cf-dns → CF_DNS, adguard → ADGUARD.
    local prefix; prefix=$(printf '%s' "$name" | tr '[:lower:]-' '[:upper:]_')

    if (( drift )); then
        new_drift "$name" "$prefix" "$target"
        return 0
    fi

    cat > "$target" <<'EOF'
#!/usr/bin/env bash
# __NAME__ <args> — one-line description
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" ""

usage() {
    cat <<HELP
Usage: __NAME__ [options] <args>

Describe what __NAME__ does.

Options:
  -h, --help    Show this help
HELP
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)  usage; exit 0 ;;
        --)         shift; break ;;
        -*)         die "usage" "unknown option: $1 (try -h)" 2 ;;
        *)          break ;;
    esac
done

echo
msg "$GREEN" "todo" "implement __NAME__"
echo
EOF
    sed -i '' "s/__NAME__/$name/g" "$target"
    chmod +x "$target"

    echo
    msg "$GREEN" "created" "bin/$name"
    msg "$DIM"   "next"    "1. implement it (tool-specific files go in lib/$name/)"
    msg "$DIM"   "next"    "2. add $name to the #compdef line in completions/_tools-suite"
    msg "$DIM"   "next"    "3. tools install && tools check"
    echo
}

# Scaffold a drift-guard tool + its config. __NAME__ / __PREFIX__ are filled in
# after the heredocs are written (the heredocs are quoted, so nothing expands).
new_drift() {
    local name="$1" prefix="$2" target="$3"

    cat > "$target" <<'EOF'
#!/usr/bin/env bash
# __NAME__ — fetch live state from an API and diff it against the vault mirror.
# Drift-guard sibling of cf-dns / adguard; show / diff / pull live in lib/drift.sh.
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" "__NAME__"
# shellcheck source=lib/drift.sh
source "$TOOLS_HOME/lib/drift.sh"

# TODO: API base for the service.
API="https://api.example.com"

# shellcheck disable=SC2153  # ${__PREFIX___VAULT_DOC} comes from config/__NAME__.sh
DRIFT_VAULT_DOC="${__PREFIX___VAULT_DOC}"
# shellcheck disable=SC2153
DRIFT_VAULT_HEADING="${__PREFIX___VAULT_HEADING}"

usage() {
    cat <<HELP
Usage: __NAME__ <command>

Commands:
  show        Fetch and print the live state (normalized, sorted JSON).
  diff        Diff live vs the vault mirror; exit 1 on drift.
  pull        Regenerate the vault mirror block from live.
  -h, help    Show this help.

Config (config/__NAME__.sh, override via env):
  __PREFIX___CREDS         age-encrypted env holding the API credential
  __PREFIX___VAULT_DOC     vault doc holding the mirror
  __PREFIX___VAULT_HEADING heading whose fenced \`\`\`json block is the mirror
HELP
}

# Decrypt the creds env and echo the secret. Stays in memory only.
# TODO: read whatever key(s) your API needs (Bearer token, user/pass, ...).
get_token() {
    [[ -f ${__PREFIX___CREDS} ]] || die "error" "creds not found: ${__PREFIX___CREDS} (see -h)"
    local token="" k v
    while IFS='=' read -r k v; do
        case $k in
            __PREFIX___TOKEN) token=$v ;;
        esac
    done < <(decrypt -p "${__PREFIX___CREDS}" 2>/dev/null) \
        || die "error" "could not decrypt ${__PREFIX___CREDS} (try: tools key test)"
    [[ -n $token ]] || die "error" "creds need __PREFIX___TOKEN=..."
    echo "$token"
}

# Fetch live state and reduce to the normalized, sorted set.
# TODO: point at the real endpoint; paginate if the API does.
fetch_live() {
    local token; token=$(get_token)
    curl -fsS "$API/TODO" \
         -H "Authorization: Bearer $token" \
         -H "Accept: application/json" 2>/dev/null \
        | normalize \
        || die "error" "live fetch failed"
}

# Normalize a raw API response (stdin) to the diffable shape. Must be idempotent
# on its own output — drift.sh re-runs it over the stored block.
# TODO: project to the meaningful fields and sort deterministically.
normalize() {
    jq -S 'map({TODO: .}) | sort_by(tostring)'
}

# lib/drift.sh provides show / diff / pull / dispatch over DRIFT_VAULT_DOC.
drift_main "$@"
EOF
    sed -i '' -e "s/__NAME__/$name/g" -e "s/__PREFIX__/$prefix/g" "$target"
    chmod +x "$target"

    local cfg="$TOOLS_HOME/config/$name.sh"
    if [[ ! -e "$cfg" ]]; then
        cat > "$cfg" <<'EOF'
# shellcheck shell=bash
# config/__NAME__.sh — __NAME__ drift checker configuration
#
# Sourced by `__NAME__`. Each variable can be overridden per-invocation.

: "${KEYS_HOME:?set in ~/.zshrc}"
: "${NOTES_HOME:?set in ~/.zshrc}"

# age-encrypted env holding the API credential(s). Contents (example):
#   __PREFIX___TOKEN=...
# Create with:  encrypt __NAME__.env   then move the .age here.
: "${__PREFIX___CREDS:=$KEYS_HOME/__NAME__/__NAME__.env.age}"

# Vault doc holding the machine-readable mirror, and the heading whose fenced
# ```json block `diff`/`pull` read and rewrite.
: "${__PREFIX___VAULT_DOC:=$NOTES_HOME/TODO.md}"
: "${__PREFIX___VAULT_HEADING:=## Canonical Records (__NAME__)}"
EOF
        sed -i '' -e "s/__NAME__/$name/g" -e "s/__PREFIX__/$prefix/g" "$cfg"
    fi

    echo
    msg "$GREEN" "created" "bin/$name (drift guard) + config/$name.sh"
    msg "$DIM"   "next"    "1. fill the TODOs: API base, get_token keys, fetch_live endpoint, normalize jq"
    msg "$DIM"   "next"    "2. set CREDS / VAULT_DOC / VAULT_HEADING in config/$name.sh"
    msg "$DIM"   "next"    "3. add $name to #compdef + a _${name//-/_} completion; seed the vault block via: $name pull"
    msg "$DIM"   "next"    "4. tools install && tools check"
    echo
}

# ---------- watch (opt-in launchd auto-sync) ----------

WATCH_LABEL="${TOOLS_WATCH_LABEL:-com.tools.vault-sync}"
WATCH_PLIST="$HOME/Library/LaunchAgents/$WATCH_LABEL.plist"
WATCH_LOG_DIR="$TOOLS_HOME/.logs"
WATCH_LOG="$WATCH_LOG_DIR/vault-sync.log"
WATCH_INTERVAL="${TOOLS_WATCH_INTERVAL:-900}"  # 15 minutes

watch_usage() {
    cat <<EOF
Usage: tools watch <enable|disable|status|run-now>

Optional launchd agent that runs 'vault sync' on a timer (every 15 min).
Off by default. The agent only fires its command when the timer triggers
— it doesn't sit running between fires.

  enable    Install and load $WATCH_PLIST.
  disable   Unload and remove the plist. Vault stops auto-syncing.
  status    Show whether the agent is loaded, plus the last few log lines.
  run-now   Run a single 'vault sync' immediately (does not affect schedule).
EOF
}

watch_enable() {
    mkdir -p "$(dirname "$WATCH_PLIST")" "$WATCH_LOG_DIR"
    cat > "$WATCH_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>$WATCH_LABEL</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-lc</string>
        <string>$TOOLS_HOME/bin/vault sync 2>&amp;1 | sed "s/^/[\$(date +%Y-%m-%dT%H:%M:%S)] /" &gt;&gt; $WATCH_LOG; exit 0</string>
    </array>
    <key>StartInterval</key>
    <integer>$WATCH_INTERVAL</integer>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>$WATCH_LOG_DIR/vault-sync.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>$WATCH_LOG_DIR/vault-sync.stderr.log</string>
</dict>
</plist>
EOF
    launchctl unload "$WATCH_PLIST" 2>/dev/null || true
    if launchctl load "$WATCH_PLIST"; then
        echo
        msg "$GREEN" "enabled" "vault sync every $((WATCH_INTERVAL/60)) min"
        msg "$DIM"   "plist"   "$WATCH_PLIST"
        msg "$DIM"   "log"     "$WATCH_LOG"
        echo
    else
        die "error" "launchctl load failed"
    fi
}

watch_disable() {
    if [[ ! -f "$WATCH_PLIST" ]]; then
        echo
        msg "$YELLOW" "disabled" "no agent installed"
        echo
        return 0
    fi
    launchctl unload "$WATCH_PLIST" 2>/dev/null || true
    rm -f "$WATCH_PLIST"
    echo
    msg "$GREEN" "disabled" "agent removed"
    echo
}

watch_status() {
    echo
    # Optional migration helper: if you previously used a different label,
    # set TOOLS_LEGACY_WATCH_LABEL to the old name to get a one-line nag
    # with the unload command. Unset (the default) means no check.
    if [[ -n "${TOOLS_LEGACY_WATCH_LABEL-}" ]]; then
        local legacy="$HOME/Library/LaunchAgents/$TOOLS_LEGACY_WATCH_LABEL.plist"
        if [[ -f "$legacy" ]]; then
            msg "$YELLOW" "legacy" "old plist found: $legacy"
            msg "$DIM"    "hint"   "launchctl unload \"$legacy\" && rm \"$legacy\" && tools watch enable"
        fi
    fi
    if [[ -f "$WATCH_PLIST" ]] && launchctl list "$WATCH_LABEL" >/dev/null 2>&1; then
        msg "$GREEN" "watch" "loaded ${DIM}(every $((WATCH_INTERVAL/60)) min)${RESET}"
    elif [[ -f "$WATCH_PLIST" ]]; then
        msg "$YELLOW" "watch" "plist exists but not loaded"
    else
        msg "$DIM" "watch" "not enabled"
        echo
        return 0
    fi
    if [[ -f "$WATCH_LOG" ]]; then
        local lines
        lines=$(wc -l < "$WATCH_LOG" | tr -d ' ')
        msg "$DIM" "log" "$WATCH_LOG ($lines lines)"
        if (( lines > 0 )); then
            echo
            tail -n 3 "$WATCH_LOG" | sed 's/^/    /'
        fi
    fi
    echo
}

cmd_watch() {
    case "${1:-}" in
        enable)      watch_enable ;;
        disable)     watch_disable ;;
        status)      watch_status ;;
        run-now)     "$TOOLS_HOME/bin/vault" sync ;;
        -h|--help|"") watch_usage ;;
        *)           die "usage" "unknown watch command: $1 (try -h)" 2 ;;
    esac
}

# ---------- key (SSH passphrase cached in macOS Keychain) ----------
# Keychain + unlock logic lives in lib/key.sh; this is the user-facing CLI.

key_usage() {
    cat <<EOF
Usage: tools key <cache|forget|status|test>

Manage the cached SSH passphrase for your age private key. Once cached,
'decrypt' and 'open-age' (and the Finder Quick Actions) run silently.

  cache    Prompt for the passphrase and store it in the login Keychain.
           Uses an osascript dialog if not on a TTY, terminal prompt if it is.
           The passphrase is validated against \$AGE_KEY before being stored.
  forget   Remove the cached passphrase. Next decrypt will prompt again.
  status   Show whether a passphrase is cached.
  test     Fetch the cached passphrase and attempt a no-op key unlock to
           verify it still matches \$AGE_KEY. Doesn't decrypt any data.

Storage: macOS login Keychain (service "$KEY_SERVICE"). Same mechanism
git-credential-osxkeychain uses for HTTPS credentials.
EOF
}

cmd_key() {
    [[ -n "${AGE_KEY:-}" ]] || die "error" "AGE_KEY not set (KEYS_HOME missing?)"
    case "${1:-status}" in
        cache)
            local pass
            pass=$(key_prompt)
            [[ -n "$pass" ]] || die "error" "no passphrase entered"
            if ! key_validate "$pass"; then
                die "error" "passphrase does not unlock $AGE_KEY"
            fi
            key_store "$pass"
            echo
            msg "$GREEN" "cached" "passphrase stored in login Keychain ${DIM}(service: $KEY_SERVICE)${RESET}"
            echo
            ;;
        forget)
            echo
            if key_has; then
                key_forget
                msg "$GREEN" "forgotten" "passphrase removed from Keychain"
            else
                msg "$DIM" "forgotten" "no cached passphrase"
            fi
            echo
            ;;
        status)
            echo
            if key_has; then
                msg "$GREEN" "key" "passphrase cached ${DIM}(decrypt runs silently)${RESET}"
            else
                msg "$YELLOW" "key" "no cached passphrase ${DIM}(run: tools key cache)${RESET}"
            fi
            echo
            ;;
        test)
            echo
            if ! key_has; then
                msg "$YELLOW" "key" "no cached passphrase"
                echo
                return 1
            fi
            local pass; pass=$(key_get)
            if key_validate "$pass"; then
                msg "$GREEN" "key" "cached passphrase unlocks $AGE_KEY"
            else
                msg "$RED" "key" "cached passphrase does NOT match $AGE_KEY ${DIM}(run: tools key cache to refresh)${RESET}"
                echo
                return 1
            fi
            echo
            ;;
        -h|--help) key_usage ;;
        *)         die "usage" "unknown key command: $1 (try -h)" 2 ;;
    esac
}

case "${1:-}" in
    status)        shift; cmd_status  "$@" ;;
    doctor)        shift; cmd_doctor  "$@" ;;
    check)         shift; cmd_check   "$@" ;;
    new)           shift; cmd_new     "$@" ;;
    install)       shift; cmd_install "$@" ;;
    watch)         shift; cmd_watch   "$@" ;;
    key)           shift; cmd_key     "$@" ;;
    -h|--help|"")  usage; exit 0 ;;
    *)             die "usage" "unknown command: $1 (try -h)" 2 ;;
esac
