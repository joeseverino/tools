#!/usr/bin/env bash
# cf-dns — fetch the live Cloudflare DNS records and diff them against the vault
# mirror. Drift-guard sibling of ts-acl / adguard; the show/diff/pull mechanics
# live in lib/drift.sh. A Zone.DNS:Read token (age-encrypted at $CF_DNS_CREDS,
# streamed via decrypt -p — no plaintext on disk) is least-privilege.
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" "cf-dns" "$@"
# shellcheck source=lib/drift.sh
source "$TOOLS_HOME/lib/drift.sh"

API="https://api.cloudflare.com/client/v4"
# New model: the cache is the `public_dns` JSON file in the infra-dataset
# registry, read/written through the vault MCP. drift.sh keys off DRIFT_DATASET_ID.
DRIFT_DATASET_ID="${CF_DNS_DATASET_ID:-public_dns}"

describe_spec() {
    desc_tool "cf-dns" "Fetch the live Cloudflare DNS records and diff them against the vault cache."
    desc_inventory "Drift guards" 100
    desc_synopsis "cf-dns <command>"
    desc_para "Records are normalized to type/name/content/proxied (+ priority for MX);"
    desc_para "Cloudflare-internal fields (id, timestamps, meta) are dropped."
    drift_describe_commands
    desc_env CF_DNS_CREDS         -- "age-encrypted env holding CF_API_TOKEN"
    desc_env CF_ZONE              -- "zone name to query (resolved to an id via the API)"
    desc_env CF_ZONE_ID           -- "pin the zone id and skip name resolution"
    desc_env CF_DNS_DATASET_ID    -- "infra-dataset id for the cache (default public_dns)"
}

# Decrypt the creds env and echo CF_API_TOKEN. The secret stays in memory for
# the life of the call — never written to disk.
get_token() {
    local creds token="" k v
    creds=$(drift_read_creds "$CF_DNS_CREDS") || return 1
    while IFS='=' read -r k v; do
        case $k in
            CF_API_TOKEN) token=$v ;;
        esac
    done <<< "$creds"
    [[ -n $token ]] || die "error" "creds need CF_API_TOKEN=..."
    echo "$token"
}

# Resolve the zone id. Honor a pinned CF_ZONE_ID; else look it up by name.
zone_id() {
    local token="$1" resp id
    if [[ -n ${CF_ZONE_ID:-} ]]; then
        echo "$CF_ZONE_ID"
        return
    fi
    resp=$(curl -fsS "$API/zones?name=$CF_ZONE&status=active" \
                -H "Authorization: Bearer $token" \
                -H "Accept: application/json" 2>/dev/null) \
        || die "error" "zone lookup failed for $CF_ZONE"
    id=$(jq -r '.result[0].id // empty' <<<"$resp")
    [[ -n $id ]] || die "error" "no zone id for $CF_ZONE (is the token scoped to it?)"
    echo "$id"
}

# Fetch every DNS record (paginated) and reduce to the normalized, sorted set.
fetch_live() {
    local token zid page=1 total=1 all="[]" resp
    token=$(get_token)
    zid=$(zone_id "$token")

    while (( page <= total )); do
        resp=$(curl -fsS "$API/zones/$zid/dns_records?per_page=100&page=$page" \
                    -H "Authorization: Bearer $token" \
                    -H "Accept: application/json" 2>/dev/null) \
            || die "error" "DNS records fetch failed (page $page)"
        all=$(jq -c --argjson acc "$all" '$acc + .result' <<<"$resp") \
            || die "error" "unexpected DNS records response (page $page)"
        total=$(jq -r '.result_info.total_pages // 1' <<<"$resp")
        (( page++ )) || true
    done

    normalize <<<"$all"
}

# Normalize a raw Cloudflare record array (stdin) to the diffable shape.
# Idempotent on its own output, as drift.sh requires.
normalize() {
    jq -S 'map({type, name, content, proxied}
               + (if .priority != null then {priority} else {} end))
           | sort_by(.type, .name, .content, (.priority // 0))'
}

drift_main "$@"
