#!/usr/bin/env bash
# decrypt <file.age>... — age-decrypt with your private key, restore original
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" crypt
source "$TOOLS_HOME/lib/key.sh"

describe_spec() {
    desc_tool "decrypt" "Age-decrypt .age files with your private key; restore originals."
    desc_synopsis "decrypt [options] <file.age>..."
    desc_para "Decrypts .age files using your default age private key. If the key is an"
    desc_para "SSH key with a passphrase, decrypt unlocks it transparently using the"
    desc_para "passphrase cached via 'tools key cache' — one prompt up front, silent"
    desc_para "forever after. With no cached passphrase, it prompts (terminal or"
    desc_para "osascript dialog, whichever is appropriate)."
    desc_opt -f --force            -- "Overwrite existing decrypted output files"
    desc_opt -k --key PATH +repeat -- "Add another identity to try (repeatable). Bypasses the cached passphrase / unlock path for that key."
    desc_opt -p --stdout           -- "Write decrypted bytes to stdout, not a file. Silent on success; status/errors go to stderr (e.g. decrypt -p secret.age | less)."
    desc_opt --no-cache            -- "Don't use the cached passphrase even if one exists. Lets age prompt directly (terminal only)."
    desc_pos file +variadic        -- "The .age file(s) to decrypt"
    desc_env KEYS_HOME             -- "Read from ~/.zshrc; resolves AGE_KEY"
    desc_env AGE_KEY               -- "Per-invocation override for the private key path"
    desc_example "decrypt notes.md.age"
    desc_example "decrypt -k ~/keys/oldkey notes.md.age"
    desc_example "decrypt -f *.age"
    desc_example "decrypt -p secret.age | less"
}

FORCE=0
STDOUT=0
NO_CACHE=0
EXTRA_KEYS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --describe)  describe_emit "$@"; exit 0 ;;
        -h|--help)   usage; exit 0 ;;
        -f|--force)  FORCE=1; shift ;;
        -p|--stdout) STDOUT=1; shift ;;
        --no-cache)  NO_CACHE=1; shift ;;
        -k|--key)
            [[ -n "${2:-}" ]] || die "usage" "-k requires a key path" 2
            EXTRA_KEYS+=("$2"); shift 2 ;;
        --)          shift; break ;;
        -*)          die_unknown option "$1" ;;
        *)           break ;;
    esac
done

[[ $# -ge 1 ]] || die "usage" "decrypt <file.age>... (try -h)" 2
command -v age >/dev/null || die "error" "age not installed (brew install age)"
[[ -f "$AGE_KEY" ]] || die "error" "no default private key at: $AGE_KEY"
(( ${#EXTRA_KEYS[@]} == 0 )) || require_files "additional key" "${EXTRA_KEYS[@]}"

# Plain if — `[[ ]] && rm` would fail as the trap's last command when no
# temp copy exists (unpassphrased key), and set -e turns that into exit 1.
cleanup_unlocked() {
    if [[ -n "$UNLOCKED_KEY" && -f "$UNLOCKED_KEY" ]]; then
        rm -f "$UNLOCKED_KEY"
    fi
}
trap cleanup_unlocked EXIT INT TERM

if (( STDOUT )); then
    exec 3>&1
    exec 1>&2
fi

# One prompt (if needed) for the whole batch. NO_CACHE is a 0/1 flag, so the
# no-cache argument needs an explicit if — `${NO_CACHE:+1}` is non-empty for
# "0" too, which bypassed the Keychain cache on every run. The status is
# captured with `|| rc=$?` because `if ! cmd` negates $? to 0, which made the
# per-cause error branches below unreachable.
no_cache_arg=""
if (( NO_CACHE )); then no_cache_arg=1; fi
rc=0
unlock_age_key "$no_cache_arg" || rc=$?
if (( rc != 0 )); then
    case $rc in
        1) die "error" "no passphrase provided" ;;
        2) die "error" "wrong passphrase for $AGE_KEY (try: tools key cache)" ;;
        3) die "error" "no private key at: $AGE_KEY" ;;
        *) die "error" "could not unlock $AGE_KEY" ;;
    esac
fi
identities=("-i" "$AGE_IDENTITY")
if (( ${#EXTRA_KEYS[@]} > 0 )); then
    for k in "${EXTRA_KEYS[@]}"; do
        identities+=("-i" "$k")
    done
fi

ok=0; failed=0; skipped=0
(( STDOUT )) || header "decrypting" "$#"

for f in "$@"; do
    if [[ ! -f "$f" ]]; then
        msg "$YELLOW" "skipped" "$f ${DIM}(not a file)${RESET}"
        skipped=$((skipped+1))
        continue
    fi
    if [[ "$f" != *.age ]]; then
        msg "$YELLOW" "skipped" "$f ${DIM}(not a .age file)${RESET}"
        skipped=$((skipped+1))
        continue
    fi
    if (( STDOUT )); then
        if err=$(age -d "${identities[@]}" "$f" 2>&1 >&3); then
            ok=$((ok+1))
        else
            msg "$RED" "failed" "$f ${DIM}($(age_reason "$err"))${RESET}"
            failed=$((failed+1))
        fi
        continue
    fi
    out="${f%.age}"
    if [[ -e "$out" && $FORCE -eq 0 ]]; then
        msg "$YELLOW" "skipped" "$f ${DIM}($out exists, -f to overwrite)${RESET}"
        skipped=$((skipped+1))
        continue
    fi
    if err=$(age -d "${identities[@]}" -o "$out" "$f" 2>&1); then
        msg "$GREEN" "decrypted" "$f ${DIM}→${RESET} $out"
        ok=$((ok+1))
    else
        msg "$RED" "failed" "$f ${DIM}($(age_reason "$err"))${RESET}"
        failed=$((failed+1))
    fi
done

(( STDOUT )) || footer "decrypted" "$ok" "$skipped" "$failed"
(( failed == 0 ))
