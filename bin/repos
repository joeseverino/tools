#!/usr/bin/env bash
# repos [options] [name] — fleet inventory of every repo under ~/Documents/Code.
# One call returns git state, package manager, CI, and last commit for every
# repo, so an agent (or human) gets the whole picture without running a dozen
# git/ls/du commands per repo. `--json` is the machine surface.
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" "" "$@"
# shellcheck source=lib/git.sh
source "$TOOLS_HOME/lib/git.sh"   # the branch-state verdict (git_branch_state) lives here, not re-derived

: "${CODE_HOME:=$HOME/Documents/Code}"

REPOS_LOCAL_OK=()
REPOS_CONFIG="${REPOS_CONFIG:-$TOOLS_HOME/config/repos.sh}"
if [[ -f "$REPOS_CONFIG" ]]; then
    # shellcheck source=config/repos.sh
    source "$REPOS_CONFIG"
fi

# The single source of truth for repos's surface: lib/describe.sh renders
# both this tool's -h text and its --describe JSON from this one declaration.
describe_spec() {
    desc_tool "repos" "Fleet inventory of every repo under ~/Documents/Code."
    desc_inventory "Workspace" 190
    desc_leaf_commands
    desc_synopsis "repos [options] [name] | repos tui [options] [name]"
    desc_effect read
    desc_opt --tui        -- "Open the interactive repo fleet explorer (can execute ship/land/resync actions)"
    desc_opt --json       -- "Machine-readable output (one JSON object, \"repos\" array)"
    desc_opt --dirty      -- "Only repos with uncommitted changes"
    desc_opt --unpushed   -- "Only repos with no remote, no upstream, or unpushed commits"
    desc_opt --prs        -- "Fold each repo's open-PR state (number, CI, review) into the output via gh (network; one gh call per repo with a remote)"
    desc_opt --fetch      -- "git fetch --prune each repo before computing ahead/behind/gone, so the remote-tracking state is true now, not as of the last manual fetch (network; slower)"
    desc_opt --pm PM      -- "Only repos whose package manager is PM (pnpm|npm|yarn|bun|none)"
    desc_opt --sizes      -- "Include node_modules size (slower; runs du)"
    desc_opt --icloud     -- "Count iCloud conflict duplicates ('name 2.ext') per repo"
    desc_opt --root DIR   -- "Scan DIR instead of the defaults (repeatable)"
    desc_pos name         -- "Only repos whose name contains NAME"
    desc_para "Default roots are \$CODE_HOME/Assets and \$CODE_HOME/Projects. A directory is listed if it is a git work tree or carries a project manifest (package.json, pyproject.toml, go.mod, Cargo.toml). Use 'repos --pm npm' to see what is left to migrate, 'repos --unpushed' before stepping away, and 'repos --json' to consume the whole fleet in one parse."
    desc_para "repos owns the read half of the workspace loop; the write half reads back from it. 'repos --prs' adds the PR/CI state ship and land act on (it is what 'land' previews against), and 'repos --fetch' makes the behind/gone signal honest before you rely on it. The behind/upstream-gone counts without --fetch are only as fresh as the last fetch in that repo."
    desc_example "repos tui" -- "open the fleet explorer"
    desc_example "repos --unpushed --json" -- "machine-read repos needing push, upstream setup, or stale-branch cleanup"
    desc_example "repos --prs --fetch --json" -- "the full honest snapshot: fresh behind/gone plus open-PR/CI state, in one parse"
    desc_cmd tui -- "Open the interactive repo dashboard and run ship/land/resync/shell actions"
    desc_effect remote_write +network +interactive
    desc_opt --dirty      -- "Start on repos with uncommitted changes"
    desc_opt --unpushed   -- "Start on repos with no remote, no upstream, unpushed commits, or gone upstream"
    desc_opt --fetch      -- "git fetch --prune each repo on load so behind/gone state is current"
    desc_opt --pm PM      -- "Only repos whose package manager is PM (pnpm|npm|yarn|bun|none)"
    desc_opt --sizes      -- "Include node_modules size (slower; runs du)"
    desc_opt --icloud     -- "Count iCloud conflict duplicates ('name 2.ext') per repo"
    desc_opt --root DIR   -- "Scan DIR instead of the defaults (repeatable)"
    desc_pos name +optional -- "Only repos whose name contains NAME"
    desc_para "The TUI renders the same repos --json fleet snapshot, then launches the existing workflow owners instead of reimplementing them: ship handles commit/push/PR, land merges the green PR, resync handles merged-branch cleanup, and shell actions drop into the selected repo. It paints from the fast local snapshot first, then hydrates open-PR/CI state (repos --prs) in the background so startup stays instant."
    desc_example "repos tui" -- "start from the workspace dashboard"
}

desc_help_intercept "$@"

# ---------- args ----------
JSON=0 TUI=0 DIRTY=0 UNPUSHED=0 SIZES=0 ICLOUD=0 PRS=0 FETCH=0
PM_FILTER="" NAME_FILTER=""
ROOTS=()
# Routed through a var so the test suite can shadow `gh` with a hermetic stub
# (no network, no auth) — same pattern as KEY_SECURITY_BIN / DRIFT_REVIEW_BIN.
GH_BIN="${GH_BIN:-gh}"
while [[ $# -gt 0 ]]; do
    case "$1" in
        tui|--tui)  TUI=1; shift ;;
        --json)     JSON=1; shift ;;
        --dirty)    DIRTY=1; shift ;;
        --unpushed) UNPUSHED=1; shift ;;
        --prs)      PRS=1; shift ;;
        --fetch)    FETCH=1; shift ;;
        --sizes)    SIZES=1; shift ;;
        --icloud)   ICLOUD=1; shift ;;
        --pm)       PM_FILTER="${2:-}"; shift 2 ;;
        --root)     ROOTS+=("${2:-}"); shift 2 ;;
        -*)         die_unknown option "$1" ;;
        *)          NAME_FILTER="$1"; shift ;;
    esac
done
(( ${#ROOTS[@]} )) || ROOTS=("$CODE_HOME/Assets" "$CODE_HOME/Projects")

# Exact-name preference: when NAME names a repo dir exactly (e.g. `cordon`), match
# ONLY that repo, never every repo that contains the string (`cordon-starter`).
# Falls back to substring when NAME matches no dir exactly, so partial names still
# work. This is what keeps `ship cordon` / `land cordon` off a sibling's branch.
NAME_EXACT=0
if [[ -n "$NAME_FILTER" ]]; then
    for root in "${ROOTS[@]}"; do
        [[ -d "$root/$NAME_FILTER" ]] && { NAME_EXACT=1; break; }
    done
fi

if (( TUI )); then
    args=()
    (( DIRTY )) && args+=(--dirty)
    (( UNPUSHED )) && args+=(--unpushed)
    (( FETCH )) && args+=(--fetch)
    (( SIZES )) && args+=(--sizes)
    (( ICLOUD )) && args+=(--icloud)
    [[ -n "$PM_FILTER" ]] && args+=(--pm "$PM_FILTER")
    for root in "${ROOTS[@]}"; do args+=(--root "$root"); done
    [[ -n "$NAME_FILTER" ]] && args+=("$NAME_FILTER")
    exec node "$TOOLS_HOME/lib/repos/tui.mjs" "${args[@]}"
fi

# ---------- per-repo collection (parallel arrays, one entry per included repo) ----------
R_NAME=() R_ROOT=() R_PATH=() R_GIT=() R_BRANCH=() R_REMOTE=() R_HASREMOTE=()
R_DIRTY=() R_UNTRACKED=() R_AHEAD=() R_BEHIND=() R_UPSTREAM=() R_UPSTREAM_NAME=()
R_UPSTREAM_TRACK=() R_UPSTREAM_GONE=()
R_SHA=() R_DATE=() R_SUBJ=() R_LANG=() R_PM=() R_PMFIELD=() R_NVMRC=()
R_NM=() R_NMSIZE=() R_CI=() R_IDUPS=() R_STASH=()
R_LOCAL_OK=() R_NEEDS_SHIP=() R_NEEDS_RESYNC=() R_NEEDS_ATTENTION=() R_STATE=()
R_PR_NUM=() R_PR_STATE=() R_PR_CI=() R_PR_REVIEW=() R_PR_URL=()

repo_local_ok() {
    local name="$1" path="$2" item
    for item in "${REPOS_LOCAL_OK[@]:-}"; do
        [[ "$item" == "$name" || "$item" == "$path" ]] && return 0
    done
    return 1
}

collect() {
    local d="$1" root_label="$2"
    local name; name="$(basename "$d")"

    # Name filter first — it depends only on the directory name, so a scoped scan
    # (`repos NAME`, and every `ship/land/resync NAME`) skips the per-repo git work
    # for the ~25 repos it doesn't want instead of paying for them and discarding.
    if [[ -n "$NAME_FILTER" ]]; then
        if (( NAME_EXACT )); then [[ "$name" != "$NAME_FILTER" ]] && return 0
        else [[ "$name" != *"$NAME_FILTER"* ]] && return 0; fi
    fi

    local is_git=0
    git -C "$d" rev-parse --is-inside-work-tree >/dev/null 2>&1 && is_git=1
    local has_manifest=0
    [[ -f "$d/package.json" || -f "$d/pyproject.toml" || -f "$d/go.mod" || -f "$d/Cargo.toml" ]] && has_manifest=1
    (( is_git || has_manifest )) || return 0

    local branch='-' remote='' has_remote=0 dirty=0 untracked=0 ahead=0 behind=0 upstream=0 upstream_name='' upstream_track='' upstream_gone=0
    local local_ok=0 needs_ship=0 needs_resync=0 needs_attention=0 stash=0
    local sha='' cdate='' subj=''
    if (( is_git )); then
        # --fetch refreshes remote-tracking refs first, so the ahead/behind/gone
        # computed below is true now, not as of the repo's last manual fetch.
        if (( FETCH )); then git -C "$d" fetch -q origin --prune 2>/dev/null || true; fi
        remote="$(git -C "$d" remote get-url origin 2>/dev/null || true)"
        [[ -n "$remote" ]] && has_remote=1
        # One `git status --porcelain=v2 --branch` (git_repo_snapshot) yields
        # branch, upstream, ahead/behind, gone, and dirty/untracked — replacing
        # six separate per-repo plumbing calls. Same cd-subshell pattern as the
        # git_branch_state call below.
        local snap; snap="$( cd "$d" && git_repo_snapshot )"
        IFS=$'\x1f' read -r branch upstream_name upstream ahead behind upstream_gone upstream_track dirty untracked <<<"$snap"
        local lc; lc="$(git -C "$d" log -1 --format='%h%x1f%cs%x1f%s' 2>/dev/null || true)"
        [[ -n "$lc" ]] && { IFS=$'\x1f' read -r sha cdate subj <<<"$lc" || true; }
        stash="$(git -C "$d" stash list 2>/dev/null | grep -c . || true)"; [[ -n "$stash" ]] || stash=0
    fi

    # Branch-state verdict from the one owner (lib/git.sh), never re-derived here.
    # want_pr=0 keeps the default tier network-free (PR knowledge folds in during
    # the --prs pass below), so a stale-looking branch that actually has an open
    # PR is corrected to "pr" only when PR state is fetched.
    local branch_state='-'
    if (( is_git )) && (( has_remote )); then
        branch_state="$( cd "$d" && git_branch_state "$(git_default_branch)" 0 2>/dev/null || echo '-' )"
        [[ -n "$branch_state" ]] || branch_state='-'
    fi

    local pm='-'
    if   [[ -f "$d/pnpm-lock.yaml" ]];                then pm=pnpm
    elif [[ -f "$d/package-lock.json" ]];             then pm=npm
    elif [[ -f "$d/yarn.lock" ]];                     then pm=yarn
    elif [[ -f "$d/bun.lockb" || -f "$d/bun.lock" ]]; then pm=bun
    elif [[ -f "$d/package.json" ]];                  then pm=none
    fi
    local lang=other
    if   [[ -f "$d/package.json" ]];                                then lang=node
    elif [[ -f "$d/pyproject.toml" || -f "$d/requirements.txt" ]];  then lang=python
    elif [[ -f "$d/go.mod" ]];                                      then lang=go
    elif [[ -f "$d/Cargo.toml" ]];                                  then lang=rust
    elif compgen -G "$d/bin/*" >/dev/null 2>&1 || compgen -G "$d/*.sh" >/dev/null 2>&1; then lang=bash
    fi
    local pmfield='-'
    if [[ -f "$d/package.json" ]]; then
        pmfield="$(grep -oE '"packageManager"[[:space:]]*:[[:space:]]*"[^"]+"' "$d/package.json" 2>/dev/null | grep -oE '"[^"]+"$' | tr -d '"' || true)"
        [[ -n "$pmfield" ]] || pmfield='-'
    fi
    local nvmrc='-'; [[ -f "$d/.nvmrc" ]] && nvmrc="$(head -1 "$d/.nvmrc" 2>/dev/null | tr -d '[:space:]' || true)"
    [[ -n "$nvmrc" ]] || nvmrc='-'

    local nm=0; [[ -d "$d/node_modules" ]] && nm=1
    local nmsize='null'
    if (( SIZES )) && (( nm )); then nmsize="\"$(du -sh "$d/node_modules" 2>/dev/null | cut -f1 || true)\""; fi
    local ci=0
    [[ -d "$d/.github/workflows" ]] && ci="$(find "$d/.github/workflows" -maxdepth 1 -type f \( -name '*.yml' -o -name '*.yaml' \) 2>/dev/null | wc -l | tr -d ' ' || true)"
    local idups=0
    if (( ICLOUD )); then
        idups="$(find "$d" -path '*/node_modules' -prune -o -path '*/.git' -prune -o -type f -name '* [0-9].*' -print 2>/dev/null | wc -l | tr -d ' ' || true)"
    fi

    repo_local_ok "$name" "$d" && local_ok=1
    (( dirty + untracked > 0 || ahead > 0 || (has_remote == 1 && upstream == 0 && local_ok == 0) )) && needs_ship=1
    (( upstream_gone > 0 || behind > 0 )) && needs_resync=1
    (( needs_ship > 0 || needs_resync > 0 || (has_remote == 0 && local_ok == 0) )) && needs_attention=1

    # filters (name already applied up top, before the git work)
    [[ -n "$PM_FILTER" && "$pm" != "$PM_FILTER" ]] && return 0
    (( DIRTY )) && (( dirty + untracked == 0 )) && return 0
    if (( UNPUSHED )); then
        (( needs_ship == 1 || needs_resync == 1 || (has_remote == 0 && local_ok == 0) )) || return 0
    fi

    # Emit ONE \x1f-delimited record (no field holds \x1f or a newline — the
    # commit subject is %s, a single line). The collect runs in parallel, one
    # subshell per repo writing its record to a temp file; merge_record reads them
    # back in order and appends to the arrays, and lib/repos/json.mjs parses the
    # same files for --json. Field ORDER is the contract, defined once in
    # lib/repos/record.mjs (RECORD_FIELDS) — this printf and merge_record below
    # both follow it, and the schema-parity test locks the JSON shape.
    printf '%s\x1f' \
        "$name" "$root_label" "$d" "$is_git" "$branch" "$remote" "$has_remote" \
        "$dirty" "$untracked" "$ahead" "$behind" "$upstream" \
        "$upstream_name" "$upstream_track" "$upstream_gone" \
        "$sha" "$cdate" "$subj" "$lang" "$pm" "$pmfield" "$nvmrc" \
        "$nm" "$nmsize" "$ci" "$idups" "$stash" \
        "$local_ok" "$needs_ship" "$needs_resync" "$needs_attention" "$branch_state"
    printf '\n'
}

# Parse one collect record and append to the parallel arrays (the merge half of
# the parallel scan). Field order mirrors collect's printf exactly.
merge_record() {
    local line="$1"
    [[ -n "$line" ]] || return 0
    local f; IFS=$'\x1f' read -r -a f <<<"$line"
    R_NAME+=("${f[0]}"); R_ROOT+=("${f[1]}"); R_PATH+=("${f[2]}")
    R_GIT+=("${f[3]}"); R_BRANCH+=("${f[4]}"); R_REMOTE+=("${f[5]}"); R_HASREMOTE+=("${f[6]}")
    R_DIRTY+=("${f[7]}"); R_UNTRACKED+=("${f[8]}"); R_AHEAD+=("${f[9]}"); R_BEHIND+=("${f[10]}"); R_UPSTREAM+=("${f[11]}")
    R_UPSTREAM_NAME+=("${f[12]}"); R_UPSTREAM_TRACK+=("${f[13]}"); R_UPSTREAM_GONE+=("${f[14]}")
    R_SHA+=("${f[15]}"); R_DATE+=("${f[16]}"); R_SUBJ+=("${f[17]}"); R_LANG+=("${f[18]}")
    R_PM+=("${f[19]}"); R_PMFIELD+=("${f[20]}"); R_NVMRC+=("${f[21]}")
    R_NM+=("${f[22]}"); R_NMSIZE+=("${f[23]}"); R_CI+=("${f[24]}"); R_IDUPS+=("${f[25]}"); R_STASH+=("${f[26]}")
    R_LOCAL_OK+=("${f[27]}"); R_NEEDS_SHIP+=("${f[28]}"); R_NEEDS_RESYNC+=("${f[29]}"); R_NEEDS_ATTENTION+=("${f[30]}"); R_STATE+=("${f[31]}")
    # PR fields default to "no open PR"; the --prs post-pass overwrites them.
    R_PR_NUM+=(0); R_PR_STATE+=("none"); R_PR_CI+=("none"); R_PR_REVIEW+=("none"); R_PR_URL+=("")
}

# Parallel scan: one collect subshell per repo (each writes its record to a temp
# file), then merge the records back in directory order. The per-repo git work
# (10+ subprocesses, or a network fetch under --fetch) dominates and is fully
# independent, so fanning it out turns a sequential ~Nx130ms walk into one bounded
# by the slowest single repo. Same temp-dir + wait pattern the --prs pass uses.
SCAN_TMP="$(mktemp -d)"
PR_TMP=""   # set by the --prs pass; json.mjs reads it, so it's cleaned at exit
trap 'rm -rf "$SCAN_TMP" "$PR_TMP"' EXIT
scan_idx=0
for root in "${ROOTS[@]}"; do
    [[ -d "$root" ]] || continue
    label="$(basename "$root")"
    for d in "$root"/*/; do
        d="${d%/}"
        [[ -d "$d" ]] || continue
        collect "$d" "$label" > "$SCAN_TMP/$scan_idx" &
        scan_idx=$(( scan_idx + 1 ))
    done
done
wait

merge_i=0
while (( merge_i < scan_idx )); do
    merge_record "$(cat "$SCAN_TMP/$merge_i" 2>/dev/null)"
    merge_i=$(( merge_i + 1 ))
done

N=${#R_NAME[@]}

# ---------- PR state (--prs) ----------
# The read owner also owns open-PR/CI state: fan one `gh pr view` out per repo
# with a remote (in parallel — gh round-trips dominate), then project every blob
# back in one node pass and splice into the parallel arrays by index. A repo with
# no gh, no auth, or no PR stays at the "none" default emitted above.
if (( PRS )) && (( N > 0 )); then
    PR_TMP="$(mktemp -d)"
    i=0
    while (( i < N )); do
        if [[ "${R_GIT[$i]}" == "1" && "${R_HASREMOTE[$i]}" == "1" && "${R_BRANCH[$i]}" != "-" ]]; then
            ( cd "${R_PATH[$i]}" && "$GH_BIN" pr view "${R_BRANCH[$i]}" \
                --json number,url,state,isDraft,reviewDecision,statusCheckRollup \
                > "$PR_TMP/$i.json" 2>/dev/null || true ) &
        fi
        i=$(( i + 1 ))
    done
    wait
    # The --json surface reads $PR_TMP directly (json.mjs projects each blob), so
    # the array splice + state correction below is only for the human render.
    if (( ! JSON )); then
        while IFS=$'\t' read -r idx num state prci review url; do
            [[ -n "$idx" ]] || continue
            R_PR_NUM[idx]="$num"; R_PR_STATE[idx]="$state"; R_PR_CI[idx]="$prci"
            R_PR_REVIEW[idx]="$review"; R_PR_URL[idx]="$url"
            # Correct the network-free hint: an open PR means the branch is its PR's
            # home (iterate), not stale — the want_pr=1 arm of git_branch_state.
            [[ "$state" == "open" ]] && R_STATE[idx]="pr"
        done < <(node "$TOOLS_HOME/lib/repos/pr.mjs" "$PR_TMP")
    fi
fi

# ---------- JSON surface ----------
# Built once from the field manifest by a real serializer (lib/repos/record.mjs +
# json.mjs), reading collect()'s records straight from the scan temp dir — no
# hand-concatenated, escape-prone printf for the fleet's most-consumed contract.
if (( JSON )); then
    json_args=(--record-dir "$SCAN_TMP" --scan-count "$scan_idx")
    for root in "${ROOTS[@]}"; do json_args+=(--root "$root"); done
    (( ICLOUD )) && json_args+=(--icloud)
    (( PRS )) && json_args+=(--pr-dir "$PR_TMP")
    node "$TOOLS_HOME/lib/repos/json.mjs" "${json_args[@]}"
    exit 0
fi

# ---------- human surface ----------
# Pad a string to WIDTH display columns. ${#s} counts characters (UTF-8 locale),
# so this aligns columns that hold multibyte glyphs (± ↑ ↓ …) where printf's
# byte-based %-Ns would not.
pad() { local s="$1" w="$2"; printf '%s' "$s"; (( ${#s} < w )) && printf '%*s' $(( w - ${#s} )) ''; }

header "repos" "$N"
if (( N == 0 )); then
    msg "$DIM" "none" "no repos matched"
    echo; exit 0
fi

if (( PRS )); then
    printf '  %s%-22s %-9s %-6s %-17s %-4s %-13s %s%s\n' "$BOLD" "REPO" "ROOT" "PM" "STATUS" "CI" "PR" "LAST COMMIT" "$RESET"
else
    printf '  %s%-22s %-9s %-6s %-17s %-4s %s%s\n' "$BOLD" "REPO" "ROOT" "PM" "STATUS" "CI" "LAST COMMIT" "$RESET"
fi
n_dirty=0 n_unpushed=0
i=0
while (( i < N )); do
    st=""
    (( ${R_HASREMOTE[$i]} == 0 && ${R_LOCAL_OK[$i]} == 0 )) && st+="local "
    (( ${R_HASREMOTE[$i]} == 0 && ${R_LOCAL_OK[$i]} == 1 )) && st+="local-ok "
    (( ${R_DIRTY[$i]} > 0 ))      && st+="±${R_DIRTY[$i]} "
    (( ${R_UNTRACKED[$i]} > 0 ))  && st+="?${R_UNTRACKED[$i]} "
    (( ${R_AHEAD[$i]} > 0 ))      && st+="↑${R_AHEAD[$i]} "
    (( ${R_BEHIND[$i]} > 0 ))     && st+="↓${R_BEHIND[$i]} "
    (( ${R_STASH[$i]} > 0 ))      && st+="⚑${R_STASH[$i]} "
    (( ${R_UPSTREAM_GONE[$i]} > 0 )) && st+="gone "
    [[ -z "$st" ]] && st="clean"; st="${st% }"
    (( ${R_DIRTY[$i]} + ${R_UNTRACKED[$i]} > 0 )) && n_dirty=$(( n_dirty + 1 ))
    (( ${R_NEEDS_ATTENTION[$i]} > 0 )) && n_unpushed=$(( n_unpushed + 1 ))

    nm="${R_NAME[$i]}"; (( ${#nm} > 22 )) && nm="${nm:0:21}…"
    subj="${R_SUBJ[$i]}"; (( ${#subj} > 42 )) && subj="${subj:0:41}…"
    ci="${R_CI[$i]}"; [[ "$ci" == "0" ]] && ci="-"
    color="$RESET"; [[ "$st" != "clean" ]] && color="$YELLOW"
    printf '  '; pad "$nm" 22
    printf ' %-9s %-6s ' "${R_ROOT[$i]}" "${R_PM[$i]}"
    printf '%s' "$color"; pad "$st" 17; printf '%s' "$RESET"
    printf ' %-4s ' "$ci"
    if (( PRS )); then
        pr=""; prcolor="$DIM"
        if [[ "${R_PR_STATE[$i]}" != "none" ]]; then
            pr="#${R_PR_NUM[$i]} ${R_PR_CI[$i]}"
            case "${R_PR_CI[$i]}" in passing) prcolor="$GREEN" ;; failing) prcolor="$RED" ;; pending) prcolor="$YELLOW" ;; esac
        else
            pr="-"
        fi
        printf '%s' "$prcolor"; pad "$pr" 13; printf '%s ' "$RESET"
    fi
    printf '%s %s\n' "${R_DATE[$i]:--}" "$subj"
    i=$(( i + 1 ))
done

echo
msg "$DIM" "summary" "$N repos · $n_dirty dirty · $n_unpushed unpushed"
echo
