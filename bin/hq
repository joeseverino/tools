#!/usr/bin/env bash
# hq — sync vault frontmatter to Severino HQ, and a few quality-of-life ops.
#
# Every `ssh "$HQ_SSH_HOST" "<remote command>"` call in this file deliberately
# expands $HQ_REMOTE_PATH on the client side — the remote shell needs the
# resolved literal path, not the env var. SC2029 flags this pattern as
# potentially ambiguous; here it's intentional.
# shellcheck disable=SC2029

set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" hq

describe_spec() {
    desc_tool "hq" "Sync vault frontmatter to Severino HQ, plus routine HQ deployment ops."
    desc_synopsis "hq <command> [args]"
    desc_para "Severino HQ glue. Reads YAML frontmatter from the vault and upserts the"
    desc_para "HQ docs index. Also wraps the routine ssh + docker compose calls for"
    desc_para "managing the HQ deployment."
    # Tool-level examples: declared at global scope (before the first desc_cmd),
    # like global desc_opt/desc_pos — otherwise they'd attach to the last command.
    desc_example "hq sync"                    -- "most common — push vault → HQ"
    desc_example "hq manifest | jq '.[] | .doc_id'"
    desc_example "hq doctor"                  -- "find docs missing frontmatter"
    desc_example "hq export 2026"             -- "download year-summary-2026.md"
    desc_cmd manifest  -- "Print the manifest JSON (frontmatter from every doc) to stdout — for inspection or piping elsewhere"

    desc_cmd sync      -- "Pipe the manifest into HQ's import_docs_manifest; upserts by doc_id, safe to re-run"
    desc_effect remote_write +network
    desc_opt --prune     -- "Delete orphan DocumentationRecord rows (doc_ids in HQ but not in the manifest), plus ContentItems linked only to them. Use after a doc_id rename or retirement"
    desc_opt --no-update -- "Only create new records; never update existing ones"

    desc_cmd doctor    -- "Report vault docs missing or with invalid frontmatter, and whether HQ's last-synced manifest is stale"

    desc_cmd schema    -- "Regenerate HQ's docs_index/schema.json from the installed MCP (the canonical frontmatter contract)"
    desc_effect local_write
    desc_opt --check     -- "Verify the HQ schema.json and the vault schema doc match the MCP; exit 1 on drift without writing (CI / pre-deploy gate)"

    desc_cmd validate  -- "Report HQ registry entries (Projects/Assets) that no vault doc references. Read-only"
    desc_effect read +network

    desc_cmd create    -- "Create or update a Project or Asset in HQ (idempotent upsert by slug)"
    desc_effect remote_write +network
    desc_pos kind "{project,asset}" -- "What to create"
    desc_pos slug      -- "Registry slug (the create_project / create_asset key)"
    desc_delegate "HQ's create_project / create_asset management commands (derived from the Django models) — run \`hq create <kind> -h\` for the live flag list (it reaches manage.py); an invalid value prints the allowed set"
    desc_example "hq create project my-site --name \"My Site\" --category cloudflare --status published --url https://example.com"
    desc_example "hq create asset example-com --name \"example.com\" --category domain"

    desc_cmd deploy    -- "Fallback: re-pull the latest scanned GHCR image and restart the container (CI's deploy step)"
    desc_effect deploy +network

    desc_cmd ship      -- "Commit + push a small HQ change. The push IS the deploy: it triggers the gated pipeline (build → scan → deploy on green)"
    desc_effect deploy +network
    desc_opt -m --message TEXT -- "Commit message for the HQ repo change (required)"

    desc_cmd logs      -- "Show app container logs (default tail 50)"
    desc_effect read +network
    desc_opt -f --follow -- "Stream live output until Ctrl-C"
    desc_opt --tail N    -- "Number of lines to show (default 50; ignored with --follow)"

    desc_cmd restart   -- "\`docker compose restart app\` — no rebuild, no migrations. For env changes or stuck state"
    desc_effect deploy +network

    desc_cmd open      -- "Open \$HQ_URL in the browser"

    desc_cmd shell     -- "ssh -t into the HQ Django shell (poke the ORM)"
    desc_effect remote_write +network +interactive

    desc_cmd superuser -- "ssh -t into HQ and run createsuperuser interactively"
    desc_effect remote_write +network +interactive

    desc_cmd export    -- "Download the year summary to ./ and print the path"
    desc_effect local_write +network
    desc_pos year +optional             -- "Year to export (default: current year)"
    desc_pos format +optional "{md,json}" -- "Output format (default: md)"
    desc_env NOTES_HOME    -- "Vault root"
    desc_env HQ_VAULT_DIRS -- "Colon-separated subdirs to index"
    desc_env HQ_SSH_HOST   -- "SSH alias of the HQ server"
    desc_env HQ_REMOTE_PATH -- "HQ checkout path on the server"
    desc_env HQ_LOCAL_PATH -- "Local HQ checkout"
    desc_env HQ_URL        -- "Public URL of HQ"
}

require_manifest_mcp() {
    command -v severino-vault-mcp >/dev/null 2>&1 \
        || die "error" "severino-vault-mcp is required; run \`site reinstall-mcp\`"
}

build_manifest() {
    require_manifest_mcp
    local help
    help="$(severino-vault-mcp --help 2>&1 || true)"
    if [[ "$help" != *"hq-manifest"* ]]; then
        die "error" "installed severino-vault-mcp is outdated; run \`site reinstall-mcp\`"
    fi
    severino-vault-mcp hq-manifest "$VAULT" "$HQ_VAULT_DIRS"
}

cmd_manifest() {
    build_manifest
}

cmd_schema() {
    local check=0
    case "${1:-}" in
        --check) check=1 ;;
        "") : ;;
        *) die_unknown flag "$1" schema ;;
    esac

    require_manifest_mcp
    if ! severino-vault-mcp schema --json >/dev/null 2>&1; then
        die "error" "installed severino-vault-mcp lacks \`schema\`; run \`site reinstall-mcp\`"
    fi

    local dest="$HQ_LOCAL_PATH/docs_index/schema.json"
    [[ -d "$HQ_LOCAL_PATH/docs_index" ]] \
        || die "error" "HQ docs_index not found at $HQ_LOCAL_PATH/docs_index"

    if [[ "$check" == "1" ]]; then
        local failed=0
        if diff -q <(severino-vault-mcp schema --json) "$dest" >/dev/null 2>&1; then
            msg "$GREEN" "ok" "docs_index/schema.json matches the MCP"
        else
            msg "$RED" "drift" "docs_index/schema.json is stale — run \`hq schema\`"
            failed=1
        fi

        local doc_out
        if [[ ! -f "$HQ_SCHEMA_DOC" ]]; then
            msg "$YELLOW" "skip" "vault schema doc not found: $HQ_SCHEMA_DOC"
        elif doc_out="$(severino-vault-mcp schema --check-doc "$HQ_SCHEMA_DOC" 2>&1)"; then
            msg "$GREEN" "ok" "vault Frontmatter Schema doc matches the MCP"
        else
            msg "$RED" "drift" "vault Frontmatter Schema doc lists stale enum values:"
            printf '%s\n' "$doc_out" | sed 's/^/  /'
            failed=1
        fi

        [[ "$failed" == "0" ]] || die "error" "schema drift — fix the above" 1
    else
        severino-vault-mcp schema --json > "$dest"
        msg "$GREEN" "wrote" "docs_index/schema.json (from the MCP)"

        local doc_out
        if [[ -f "$HQ_SCHEMA_DOC" ]] \
            && ! doc_out="$(severino-vault-mcp schema --check-doc "$HQ_SCHEMA_DOC" 2>&1)"; then
            msg "$YELLOW" "warn" "vault Frontmatter Schema doc lists stale enum values:"
            printf '%s\n' "$doc_out" | sed 's/^/  /'
            msg "$DIM" "fix" "update the enum lines in $HQ_SCHEMA_DOC by hand"
        fi
        msg "$DIM" "next" "commit schema.json + deploy HQ so the contract ships"
    fi
}

# Non-fatal preflight: warn if HQ's committed schema.json lags the installed
# MCP. A stale contract means the deployed importer can reject docs the MCP
# considers valid. Best-effort — silent if the MCP or the file is absent.
schema_drift_warn() {
    command -v severino-vault-mcp >/dev/null 2>&1 || return 0
    severino-vault-mcp schema --json >/dev/null 2>&1 || return 0
    local dest="$HQ_LOCAL_PATH/docs_index/schema.json"
    [[ -f "$dest" ]] || return 0
    if ! diff -q <(severino-vault-mcp schema --json) "$dest" >/dev/null 2>&1; then
        msg "$YELLOW" "schema" \
            "HQ docs_index/schema.json lags the MCP — run \`hq schema\`, commit, deploy"
    fi
}

cmd_sync() {
    local extra_flags=""
    local prune="0"
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --prune) extra_flags="$extra_flags --prune"; prune="1"; shift ;;
            --no-update) extra_flags="$extra_flags --no-update"; shift ;;
            *) die_unknown flag "$1" sync ;;
        esac
    done

    schema_drift_warn

    local tmp
    tmp="$(mktemp -t hq-manifest.XXXXXX.json)"
    trap 'rm -f "${tmp:-}"' EXIT

    build_manifest > "$tmp"

    msg "$DIM" "sync" "vault → HQ"
    local stats_json
    stats_json="$(
        ssh "$HQ_SSH_HOST" \
            "cd '$HQ_REMOTE_PATH' && sudo docker compose exec -T app python manage.py import_docs_manifest --json --report-orphans$extra_flags -" \
            < "$tmp"
    )"

    python3 - "$tmp" "$stats_json" "$prune" <<'PY'
import json
import sys

manifest_path, raw_stats, prune_flag = sys.argv[1], sys.argv[2], sys.argv[3]
manifest = json.load(open(manifest_path, encoding="utf-8"))
stats = json.loads(raw_stats)
prune = prune_flag == "1"

created = stats.get("created", 0)
updated = stats.get("updated", 0)
doc_pruned = stats.get("orphans_pruned", 0)
content_synced = stats.get("content_items_synced", 0)
content_pruned = stats.get("content_items_pruned", 0)
missing = stats.get("missing_relations", 0)
orphans = stats.get("orphans") or []

print(f"Docs      {len(manifest)} indexed")

changes = []
if created:
    changes.append(f"{created} created")
if updated:
    changes.append(f"{updated} updated")
if doc_pruned:
    changes.append(f"{doc_pruned} removed")
print(f"Changes   {', '.join(changes) if changes else 'none'}")

if missing:
    print(f"Relations {missing} missing")
    for item in stats.get("missing_relations_detail", [])[:8]:
        print(f"          {item['doc_id']} → missing {item['kind']} {item['slug']}")
else:
    print("Relations ok")

content = []
if content_synced:
    content.append(f"{content_synced} mirrored")
if content_pruned:
    content.append(f"{content_pruned} stale removed")
print(f"Content   {', '.join(content) if content else 'none'}")

if orphans:
    if prune:
        print(f"Cleanup   pruned {len(orphans)} orphan doc row(s)")
    else:
        print(f"Cleanup   {len(orphans)} orphan doc row(s); run `hq sync --prune`")
        for doc_id in orphans[:8]:
            print(f"          {doc_id}")
else:
    print("Cleanup   no orphans")

if missing or (orphans and not prune):
    print("Done      synced with cleanup needed")
else:
    print("Done      HQ is in sync")
PY

    # Record what shipped — manifest hash plus the exact inputs — so
    # `vault status` and `hq doctor` can detect staleness deterministically
    # (see hq_sync_freshness in lib/common.sh).
    local state_file vault_head
    state_file="$(hq_sync_state_file)"
    mkdir -p "$(dirname "$state_file")"
    vault_head="$(git -C "$VAULT" rev-parse HEAD 2>/dev/null || echo unknown)"
    python3 -c '
import hashlib, json, sys
from datetime import datetime, timezone

manifest, state, vault, dirs, head = sys.argv[1:6]
with open(manifest, "rb") as fh:
    sha = hashlib.sha256(fh.read()).hexdigest()
with open(state, "w", encoding="utf-8") as fh:
    json.dump(
        {
            "manifest_sha256": sha,
            "vault": vault,
            "vault_dirs": dirs,
            "vault_head": head,
            "synced_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        },
        fh,
        indent=2,
    )
    fh.write("\n")
' "$tmp" "$state_file" "$VAULT" "$HQ_VAULT_DIRS" "$vault_head"
}

cmd_doctor() {
    # The "what counts as a valid indexed doc" contract (skip rules, slim
    # writeup/page tolerance) lives once, in the MCP's manifest generator. Ask
    # it for the structured report instead of re-walking the vault here.
    require_manifest_mcp
    local report
    report="$(severino-vault-mcp hq-manifest "$VAULT" "$HQ_VAULT_DIRS" --report 2>/dev/null)" \
        || true
    [[ -n "$report" ]] \
        || die "error" "hq-manifest --report returned nothing; run \`site reinstall-mcp\`"

    local rc=0
    printf '%s' "$report" | python3 -c '
import json, sys

r = json.load(sys.stdin)
missing = r.get("missing_frontmatter", [])
dups = r.get("duplicates", [])

if not missing and not dups:
    print("ok: %s indexed docs have valid frontmatter" % r.get("count", 0))
    sys.exit(0)

if dups:
    print("%d duplicate doc_id(s):" % len(dups))
    for d in dups:
        print("  - %s: %s  <->  %s" % (d["doc_id"], d["first"], d["second"]))
if missing:
    print("%d doc(s) missing or invalid frontmatter:" % len(missing))
    for path in missing:
        print("  - " + path)
sys.exit(1)
' || rc=1

    # The other half of "the gap between vault state and HQ state": is the
    # manifest HQ holds the one the vault produces right now?
    local fresh
    fresh="$(hq_sync_freshness "$VAULT")"
    case "$fresh" in
        never)  msg "$YELLOW" "sync" "no recorded hq sync yet — run \`hq sync\`" ;;
        skip)   ;;
        fresh*) msg "$GREEN"  "sync" "HQ matches the vault manifest (last sync ${fresh#fresh })" ;;
        stale*) msg "$YELLOW" "sync" "doc metadata changed since the last sync (${fresh#stale }) — run \`hq sync\`"
                rc=1 ;;
    esac
    return "$rc"
}

cmd_validate() {
    msg "$DIM" "validate" "HQ registry ↔ vault docs"
    # Logic lives in the testable manage.py audit_registry command, not an
    # inline ORM script piped into `manage.py shell`.
    ssh "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose exec -T app python manage.py audit_registry"
}

cmd_create() {
    local kind="${1:-}"
    local mgmt=""
    case "$kind" in
        project) shift; mgmt="create_project" ;;
        asset)   shift; mgmt="create_asset" ;;
        # `hq create` (no kind) shows the spec-derived help; `hq create -h` is
        # handled centrally; `hq create <kind> -h` falls through to manage.py.
        "")      usage_command create; return 0 ;;
        *) die_unknown kind "$kind" create ;;
    esac

    [ "$#" -ge 1 ] || die "missing <slug>; try \`hq create $kind -h\`"

    local remote_cmd="cd '$HQ_REMOTE_PATH' && sudo docker compose exec -T app python manage.py $mgmt"
    local arg
    for arg in "$@"; do
        remote_cmd+=" $(printf '%q' "$arg")"
    done

    msg "$DIM" "hq" "$mgmt $1"
    ssh "$HQ_SSH_HOST" "$remote_cmd"
}

cmd_deploy() {
    case "${1:-}" in
        "") ;;
        *) die_unknown flag "$1" deploy ;;
    esac

    msg "$DIM" "deploying" "$HQ_SSH_HOST: pull scanned GHCR image + restart"
    ssh "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose pull app && sudo docker compose up -d --no-build app"
    msg "$GREEN" "deployed" "severino-hq (last published image)"
}

cmd_ship() {
    local message=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            -m|--message) message="${2:?--message needs text}"; shift 2 ;;
            --message=*) message="${1#--message=}"; shift ;;
            *) die_unknown flag "$1" ship ;;
        esac
    done

    [[ -n "$message" ]] || die "usage" "missing -m \"commit message\""
    [[ -d "$HQ_LOCAL_PATH/.git" ]] || die "error" "HQ_LOCAL_PATH is not a git repo: $HQ_LOCAL_PATH"

    msg "$DIM" "checking" "$HQ_LOCAL_PATH (py_compile)"
    (
        cd "$HQ_LOCAL_PATH"
        git ls-files '*.py' | xargs python3 -m py_compile
    )

    if [[ -z "$(git -C "$HQ_LOCAL_PATH" status --porcelain)" ]]; then
        msg "$GREEN" "clean" "no local HQ changes to commit"
        return 0
    fi

    msg "$DIM" "staging" "tracked changes + known HQ app files"
    (
        cd "$HQ_LOCAL_PATH"
        git add -u
        git add \
            assets content core docs docs_index expenses projects receipts reports \
            static templates \
            2>/dev/null || true
    )

    if git -C "$HQ_LOCAL_PATH" diff --cached --quiet; then
        msg "$YELLOW" "skipped" "no committable HQ changes staged"
        return 0
    fi

    git -C "$HQ_LOCAL_PATH" commit -m "$message"
    git -C "$HQ_LOCAL_PATH" push
    msg "$GREEN" "pushed" "the pipeline will build -> scan -> deploy on green"
    msg "$DIM"   "watch"  "gh run watch   (or the Actions tab)"

    if [[ -n "$(git -C "$VAULT" status --porcelain 2>/dev/null || true)" ]]; then
        msg "$YELLOW" "vault" "has uncommitted changes; run vault status/sync when ready"
    fi
}

cmd_logs() {
    local tail="50"
    local follow=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            -f|--follow) follow="-f"; shift ;;
            --tail) tail="${2:?--tail needs a number}"; shift 2 ;;
            --tail=*) tail="${1#--tail=}"; shift ;;
            *) die_unknown flag "$1" logs ;;
        esac
    done

    if [ -n "$follow" ]; then
        ssh -t "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose logs app -f"
    else
        ssh "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose logs app --tail $tail"
    fi
}

cmd_restart() {
    msg "$DIM" "restarting" "severino-hq"
    ssh "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose restart app"
    msg "$GREEN" "restarted" "severino-hq"
}

cmd_open() {
    if command -v open >/dev/null 2>&1; then
        open "$HQ_URL"
    else
        msg "$DIM" "open" "$HQ_URL"
    fi
}

cmd_shell() {
    ssh -t "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose exec app python manage.py shell"
}

cmd_superuser() {
    ssh -t "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose exec app python manage.py createsuperuser"
}

cmd_export() {
    local year="${1:-$(date +%Y)}"
    local fmt="${2:-md}"
    case "$fmt" in
        md|markdown) ext="md"; route="year-summary.md" ;;
        json) ext="json"; route="year-summary.json" ;;
        *) die_unknown format "$fmt" export ;;
    esac
    local out="year-summary-$year.$ext"
    msg "$DIM" "fetching" "$HQ_URL/reports/export/$route?year=$year"
    # Use curl with the system's resolver — Tailscale + AdGuard handle DNS.
    # The endpoint requires auth; this expects /tmp/hq-cookies.txt to exist
    # from a prior browser sign-in via `tailscale + browser`. If absent, run
    # `hq open` and sign in, then re-export.
    curl -fsSL --cookie-jar /tmp/hq-cookies.txt --cookie /tmp/hq-cookies.txt \
        "$HQ_URL/reports/export/$route?year=$year" -o "$out"
    msg "$GREEN" "wrote" "$out"
    printf '%s\n' "$out"
}

# All help + the machine surface (main `-h`, `--describe`, focused `<cmd> -h`)
# render from the one spec via the shared intercept; below is just command →
# action. `hq create <kind> -h` still reaches manage.py (the owner of those
# flags), since the intercept only fires when the help flag is the 2nd arg.
desc_help_intercept "$@"
case "${1:-}" in
    manifest)   shift; cmd_manifest "$@" ;;
    sync)       shift; cmd_sync "$@" ;;
    doctor)     shift; cmd_doctor "$@" ;;
    schema)     shift; cmd_schema "$@" ;;
    validate)   shift; cmd_validate "$@" ;;
    create)     shift; cmd_create "$@" ;;
    deploy)     shift; cmd_deploy "$@" ;;
    ship)       shift; cmd_ship "$@" ;;
    logs)       shift; cmd_logs "$@" ;;
    restart)    shift; cmd_restart "$@" ;;
    open)       shift; cmd_open "$@" ;;
    shell)      shift; cmd_shell "$@" ;;
    superuser)  shift; cmd_superuser "$@" ;;
    export)     shift; cmd_export "$@" ;;
    *) die_unknown command "$1" ;;
esac
