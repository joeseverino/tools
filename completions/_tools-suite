#compdef tools vault encrypt decrypt inbox backup open-age dns-test site hq remember brand ts-acl cf-dns adguard doc-to-pdf
# Completion for the personal CLI tools.
#
# Install by adding to ~/.zshrc, BEFORE `compinit`:
#
#     fpath=("$TOOLS_HOME/completions" $fpath)
#
# Then restart your shell (or `autoload -U compinit && compinit`).

_tools_keyfiles() {
    # Suggest .pub for encrypt -k, raw key paths for decrypt -k.
    local pattern="$1"
    _files -g "$pattern"
}

_tools() {
    local -a subs watch_subs key_subs
    subs=(
        'status:vault + inbox + backup health check'
        'doctor:verify env, deps, and installed symlinks'
        'check:run the full CI suite locally (lint, tests, bench)'
        'new:scaffold a new tool in bin/'
        'install:create symlinks for every tool'
        'key:cache / forget / test the age key passphrase'
        'watch:manage the launchd auto-sync agent'
    )
    watch_subs=(
        'enable:install and load the auto-sync agent'
        'disable:unload and remove the agent'
        'status:show whether the agent is loaded + log tail'
        'run-now:run vault sync once, no schedule change'
    )
    key_subs=(
        'cache:prompt for passphrase and store it in login Keychain'
        'forget:remove the cached passphrase'
        'status:show whether a passphrase is cached'
        'test:verify the cached passphrase still unlocks $AGE_KEY'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '2: :->subcmd'
    case $state in
        cmd)    _describe 'subcommand' subs ;;
        subcmd)
            case $words[2] in
                watch)         _describe 'watch subcommand' watch_subs ;;
                key)           _describe 'key subcommand'   key_subs ;;
                status|doctor) _arguments '--json[machine-readable output]' ;;
                check)         _arguments '--no-bench[skip the bench scripts]' ;;
            esac
            ;;
    esac
}

_vault() {
    local -a subs
    subs=(
        'sync:git pull --rebase, then git push'
        'status:working tree, inbox count, remote sync state'
        'inbox:list pending notes in the inbox'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1: :->cmd'
    case $state in
        cmd) _describe 'subcommand' subs ;;
    esac
}

_site() {
    local -a subs
    subs=(
        'status:show site repo, git, dist, and content state'
        'sync:sync public pages/writeups from the vault'
        'check:run Astro diagnostics'
        'build:run the Astro production build'
        'publish:gate, build, ship, and verify — the one-command publish'
        'publish-all:alias of publish'
        'publish-writeup:gate one slug explicitly, then publish'
        'new-writeup:scaffold a vault writeup from the template'
        'validate:run the writeup publish gate, report only'
        'tech:list technology slugs from the vault catalog'
        'featured:show or reorder the home-page featured list'
        'manage:interactive manager — feature, reorder, publish'
        'verify:re-run the live checks for one writeup'
        'diagnose:collect-all gate — every audit in one pass'
        'doctor:pre-flight health check, no build'
        'test:run the Playwright suite'
        'release:bump, check, tag, push, GitHub release'
        'seo:preview the Google-style search snippet'
        'og:regenerate the Open Graph social card'
        'contrast:WCAG ratios for text/background pairs'
        'parity:assert schema, Zod, and MCP agree on writeup fields'
        'sign-security:clear-sign security.txt'
        'check-security:verify security.txt signature and fields'
        'scaffold-primer:scaffold a 04 Reference primer'
        'scaffold-field:patch every layer for a new writeup field'
        'draft-alt:draft cover_alt from the cover image'
        'reinstall-mcp:reinstall severino-vault-mcp from source'
        'dev:start the local Astro dev server'
        'open:open the local dev URL'
        'compare:open a resizable dev-vs-live browser comparison'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::compare option:->compare'
    case $state in
        cmd) _describe 'subcommand' subs ;;
        compare)
            if [[ $words[2] == compare ]]; then
                _arguments \
                    '--mobile[start with fixed phone-width panes]' \
                    '--desktop[start with fluid desktop panes]' \
                    '--compact[start with collapsed review chrome]' \
                    '--expanded[start with expanded review chrome]' \
                    '--link-scroll[synchronize proportional scrolling]' \
                    '--no-link-scroll[keep scrolling independent]' \
                    '--scroll-mode[scroll synchronization mode]:mode:(exact ratio)' \
                    '--mirror-links[mirror internal link clicks]' \
                    '--no-mirror-links[keep link navigation independent]' \
                    '--notes[open the review-notes drawer]' \
                    '*--note[add a review note]:note text:' \
                    '--split[initial divider percent]:percent:' \
                    '--swap[start with LIVE on the left]' \
                    '--solo[show one pane and swap between DEV and LIVE]' \
                    '--split-view[show both panes]' \
                    '--focus[side initially visible in solo mode]:side:(dev live)' \
                    '--no-open[print URL without opening Safari]' \
                    '*:route:'
            fi
            ;;
    esac
}

_encrypt() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-c --copy)'{-c,--copy}'[keep the original file]' \
        '(-f --force)'{-f,--force}'[overwrite existing .age outputs]' \
        '*'{-k,--key}'[add another public key recipient]:public key:_files -g "*.pub"' \
        '*:file:_files'
}

_decrypt() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-f --force)'{-f,--force}'[overwrite existing decrypted outputs]' \
        '(-p --stdout)'{-p,--stdout}'[write decrypted bytes to stdout]' \
        '--no-cache[skip the cached passphrase, let age prompt directly]' \
        '*'{-k,--key}'[add another identity (private key)]:private key:_files' \
        '*:.age file:_files -g "*.age"'
}

_open_age() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '--no-cache[skip the cached passphrase, let age prompt directly]' \
        '1:.age file:_files -g "*.age"'
}

_inbox() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-e --edit)'{-e,--edit}'[open the captured note in $EDITOR]' \
        '*::text:'
}

_backup() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-n --dry-run)'{-n,--dry-run}'[show what would be copied; do not write]' \
        '--no-commit[skip the auto-commit step]'
}

_dns_test() {
    _arguments \
        '(-h)-h[show help]' \
        '-d[domain to query]:domain' \
        '-n[queries per path]:count' \
        '-a[AdGuard LAN IP]:ip' \
        '-b[baseline path label]:label:(System\ DNS AdGuard\ LAN Cloudflare\ 1.1.1.1 Cloudflare\ DoH)'
}

_hq() {
    local -a subs create_subs
    subs=(
        'sync:walk vault → push manifest → HQ (upsert by doc_id)'
        'doctor:report docs missing or with invalid frontmatter'
        'validate:report registry Projects/Assets no doc references'
        'manifest:print the manifest JSON to stdout'
        'create:upsert a Project or Asset record'
        'deploy:git pull + docker compose up -d --build'
        'ship:commit + push + deploy + check + sync (small-fix path)'
        'logs:show app container logs'
        'restart:docker compose restart app (no rebuild)'
        'open:open $HQ_URL in the browser'
        'shell:ssh into the HQ Django shell'
        'superuser:ssh in and run createsuperuser'
        'export:download the year summary (.md/.json)'
    )
    create_subs=(
        'project:create or update a Project record'
        'asset:create or update an Asset record'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '2: :->subcmd'
    case $state in
        cmd) _describe 'subcommand' subs ;;
        subcmd)
            case $words[2] in
                create) _describe 'create kind' create_subs ;;
            esac
            ;;
    esac
}

_cf_dns() {
    local -a subs
    subs=(
        'show:print the live DNS records (normalized, sorted JSON)'
        'diff:diff live vs the vault mirror; exit 1 on drift'
        'pull:regenerate the vault mirror block from the live zone'
    )
    _arguments -C '1: :->cmd'
    case $state in
        cmd) _describe 'subcommand' subs ;;
    esac
}

_adguard() {
    local -a subs
    subs=(
        'show:print the live DNS rewrites (normalized, sorted JSON)'
        'diff:diff live vs the vault mirror; exit 1 on drift'
        'pull:regenerate the vault mirror block from the live rewrites'
    )
    _arguments -C '1: :->cmd'
    case $state in
        cmd) _describe 'subcommand' subs ;;
    esac
}

_ts_acl() {
    local -a subs
    subs=(
        'show:print the live ACL policy (sorted JSON)'
        'diff:diff live vs the vault mirror; exit 1 on drift'
        'pull:regenerate the vault mirror block from the live ACL'
    )
    _arguments -C '1: :->cmd'
    case $state in
        cmd) _describe 'subcommand' subs ;;
    esac
}

case "$service" in
    tools)    _tools    "$@" ;;
    vault)    _vault    "$@" ;;
    encrypt)  _encrypt  "$@" ;;
    decrypt)  _decrypt  "$@" ;;
    inbox)    _inbox    "$@" ;;
    backup)   _backup   "$@" ;;
    open-age) _open_age "$@" ;;
    dns-test) _dns_test "$@" ;;
    site)     _site     "$@" ;;
    hq)       _hq       "$@" ;;
    cf-dns)   _cf_dns   "$@" ;;
    adguard)  _adguard  "$@" ;;
    ts-acl)   _ts_acl   "$@" ;;
    remember|brand|doc-to-pdf) _files ;;
esac
