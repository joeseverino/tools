#!/usr/bin/env bash
# site <command> — public jseverino.com Astro site workflow
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" ""

CODE_HOME="${CODE_HOME:-$HOME/Documents/Code}"
SITE_HOME="${SITE_HOME:-$CODE_HOME/Projects/jseverino-site}"
NOTES_HOME="${NOTES_HOME:-$CODE_HOME/Severino Labs}"
SITE_DEV_HOST="${SITE_DEV_HOST:-127.0.0.1}"
SITE_DEV_PORT="${SITE_DEV_PORT:-4321}"

if [[ -f "$TOOLS_HOME/config/site.sh" ]]; then
    # shellcheck source=config/site.sh
    source "$TOOLS_HOME/config/site.sh"
fi

usage() {
    cat <<EOF
Usage: site <command>

Commands:
  status              Show repo location, git state, and build-output state
  sync                Sync public pages/writeups from the vault into the site repo
  check               Run Astro diagnostics
  build               Run the full Astro build
  publish             Clean, sync, check, build, and audit assets
  publish-all         hq sync + site publish + push site repo. The full
                      vault-to-live-edge orchestrator.
  new-writeup <slug>  Scaffold a new vault writeup folder from the template.
                      Creates 05 Writeups/<slug>/ with index.md and images/.
                      Starts as published: false so it stays out of the build
                      until you flip it.
  dev                 Start the local Astro dev server
  open                Open the local dev URL in the browser
  -h, --help          Show this help

Environment:
  CODE_HOME       Defaults to ~/Documents/Code
  SITE_HOME       Defaults to \$CODE_HOME/Projects/jseverino-site
  NOTES_HOME      Defaults to \$CODE_HOME/Severino Labs (vault root)
  SITE_DEV_HOST   Defaults to 127.0.0.1
  SITE_DEV_PORT   Defaults to 4321
EOF
}

require_site() {
    [[ -d "$SITE_HOME" ]] || die "error" "site repo not found: $SITE_HOME"
    [[ -f "$SITE_HOME/package.json" ]] || die "error" "package.json not found in $SITE_HOME"
}

run_npm() {
    require_site
    msg "$DIM" "site" "$SITE_HOME"
    (cd "$SITE_HOME" && npm run "$@")
}

cmd_status() {
    require_site
    echo
    msg "$RESET" "site" "$SITE_HOME"

    if [[ -d "$SITE_HOME/.git" ]]; then
        local tree remote tree_color="$GREEN" remote_color="$GREEN"
        tree=$(vault_tree "$SITE_HOME")
        remote=$(vault_remote "$SITE_HOME")
        [[ "$tree" != "clean" ]] && tree_color="$YELLOW"
        [[ "$remote" != "in sync" ]] && remote_color="$YELLOW"
        msg "$RESET" "git" "${tree_color}${tree}${RESET}, ${remote_color}${remote}${RESET}"
    else
        msg "$YELLOW" "git" "not initialized"
    fi

    if [[ -d "$SITE_HOME/dist" ]]; then
        msg "$GREEN" "dist" "present"
    else
        msg "$DIM" "dist" "not built"
    fi

    if [[ -d "$SITE_HOME/src/content" ]]; then
        msg "$GREEN" "content" "synced snapshot present"
    else
        msg "$YELLOW" "content" "missing"
    fi
    echo
}

cmd_dev() {
    require_site
    msg "$DIM" "site" "$SITE_HOME"
    (cd "$SITE_HOME" && npm run dev -- --host "$SITE_DEV_HOST" --port "$SITE_DEV_PORT")
}

cmd_open() {
    require_site
    open "http://$SITE_DEV_HOST:$SITE_DEV_PORT/"
}

cmd_new_writeup() {
    local slug="${1:-}"
    if [[ -z "$slug" || "$slug" == "-h" || "$slug" == "--help" ]]; then
        cat <<HELP
Usage: site new-writeup <slug>

Scaffold a new vault writeup at 05 Writeups/<slug>/ from the Writeup template.
The slug becomes the public URL path: jseverino.com/portfolio/<slug>/

Created files:
  05 Writeups/<slug>/index.md     # frontmatter pre-filled; published: false
  05 Writeups/<slug>/images/      # empty; drop cover.png + screenshots here

The writeup stays out of the site build until you flip published: true.
HELP
        return 0
    fi

    # Slug hygiene: lowercase, alphanum + hyphens only.
    if [[ ! "$slug" =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]]; then
        die "error" "slug must be lowercase-kebab-case: '$slug' is not (use a-z, 0-9, hyphens)"
    fi

    local writeups_root="$NOTES_HOME/05 Writeups"
    local target="$writeups_root/$slug"
    local template="$NOTES_HOME/00 Templates/Writeup.md"

    [[ -d "$writeups_root" ]] || die "error" "05 Writeups not found at $writeups_root"
    [[ -f "$template" ]] || die "error" "Writeup template not found at $template"
    [[ ! -e "$target" ]] || die "error" "writeup already exists: $target"

    mkdir -p "$target/images"

    local today; today="$(date +%Y-%m-%d)"
    # {{date:YYYY-MM-DD}} → today; {{title}} → the slug (user edits both).
    sed \
        -e "s/{{date:YYYY-MM-DD}}/$today/g" \
        -e "s/{{title}}/$slug/g" \
        "$template" > "$target/index.md"

    msg "$GREEN" "created" "$target/index.md"
    msg "$DIM" "next" "edit title + description, drop cover.png in images/, flip published: true when ready"
}

cmd_publish_all() {
    local skip_push=""
    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            --no-push) skip_push="1"; shift ;;
            -h|--help)
                cat <<HELP
Usage: site publish-all [--no-push]

The full vault-to-live-edge orchestrator. Runs:

  1. hq sync                 vault frontmatter → HQ
  2. site publish            clean + sync + astro check + build + audit
  3. git push (site repo)    triggers the Cloudflare Pages build

Cloudflare picks up the push and rebuilds within ~30s. Use this for the
common case "I edited a writeup or page; ship it."

  --no-push   Stop after the local build. Useful when you want to inspect
              the diff before pushing.

Drafts (published: false) are kept in the vault, surface in HQ as Draft,
and are NOT pushed to the site repo.
HELP
                return 0 ;;
            *) die "error" "unknown flag: $1 (try \`site publish-all --help\`)" ;;
        esac
    done

    require_site
    command -v hq >/dev/null 2>&1 || die "error" "hq CLI not on PATH"

    msg "$DIM" "step 1/3" "hq sync"
    hq sync

    msg "$DIM" "step 2/3" "site publish"
    (cd "$SITE_HOME" && npm run publish:check)

    if [[ -n "$skip_push" ]]; then
        msg "$YELLOW" "step 3/3" "skipped (--no-push). Inspect with \`site status\` and push manually."
        return 0
    fi

    msg "$DIM" "step 3/3" "git push (site repo)"
    if ! (cd "$SITE_HOME" && git diff --quiet && git diff --cached --quiet); then
        msg "$YELLOW" "uncommitted" "site repo has local changes — commit them before publish-all completes"
        (cd "$SITE_HOME" && git status --short)
        die "error" "refusing to push with uncommitted changes; commit first or use --no-push"
    fi
    (cd "$SITE_HOME" && git push)
    msg "$GREEN" "shipped" "Cloudflare Pages will rebuild from the new HEAD"
}

case "${1:-}" in
    status)         shift; cmd_status "$@" ;;
    sync)           shift; run_npm sync:content "$@" ;;
    check)          shift; run_npm check "$@" ;;
    build)          shift; run_npm build "$@" ;;
    publish)        shift; run_npm publish:check "$@" ;;
    publish-all)    shift; cmd_publish_all "$@" ;;
    new-writeup)    shift; cmd_new_writeup "$@" ;;
    dev)            shift; cmd_dev "$@" ;;
    open)           shift; cmd_open "$@" ;;
    -h|--help|"")   usage; exit 0 ;;
    *)              die "usage" "unknown command: $1 (try -h)" 2 ;;
esac
