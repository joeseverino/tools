#!/usr/bin/env bash
# Hermetic `gh` stub for repos --prs / land tests. No network, no auth.
#
# `gh pr view <branch> --json …` emits canned PR JSON keyed off the branch name
# (so a fixture repo on `ship/green` looks like an open, green, approved PR);
# unknown branches exit non-zero like a real branch with no PR. `gh pr merge …`
# appends its argv to $GH_MERGE_LOG and succeeds, so a test can assert the merge
# was issued without anything leaving the machine.
set -euo pipefail

if [[ "${1:-}" == "pr" && "${2:-}" == "view" ]]; then
    branch="${3:-}"
    case "$branch" in
        ship/green|feat/green)
            cat <<'JSON'
{"number":12,"url":"https://github.com/demo/x/pull/12","state":"OPEN","isDraft":false,"reviewDecision":"APPROVED","statusCheckRollup":[{"status":"COMPLETED","conclusion":"SUCCESS"}]}
JSON
            ;;
        ship/red|feat/red)
            cat <<'JSON'
{"number":13,"url":"https://github.com/demo/x/pull/13","state":"OPEN","isDraft":false,"reviewDecision":"REVIEW_REQUIRED","statusCheckRollup":[{"status":"COMPLETED","conclusion":"FAILURE"}]}
JSON
            ;;
        ship/pending|feat/pending)
            cat <<'JSON'
{"number":14,"url":"https://github.com/demo/x/pull/14","state":"OPEN","isDraft":false,"reviewDecision":"","statusCheckRollup":[{"status":"IN_PROGRESS","conclusion":""}]}
JSON
            ;;
        *)
            exit 1
            ;;
    esac
    exit 0
fi

if [[ "${1:-}" == "pr" && "${2:-}" == "merge" ]]; then
    echo "merge $*" >> "${GH_MERGE_LOG:-/dev/null}"
    exit 0
fi

# `gh pr list --head <b> [--state open|merged] --json <f> -q '.[0].<f>'` — used by
# git_branch_has_open_pr / git_branch_pr_merged / git_open_or_update_pr. These
# callers extract a bare scalar via -q, so the stub emits the bare value (like
# real gh with -q), or NOTHING when there is no matching PR — never a literal
# "[]", which would read as "a PR exists". Branches opt in by name: *haspr* = an
# open PR, *wasmerged* = a merged PR. State-aware so open/merged don't cross-fire.
if [[ "${1:-}" == "pr" && "${2:-}" == "list" ]]; then
    head=""; state="open"; want_url=0; prev=""
    for a in "$@"; do
        [[ "$prev" == "--head" ]] && head="$a"
        [[ "$prev" == "--state" ]] && state="$a"
        [[ "$a" == *url* ]] && want_url=1
        prev="$a"
    done
    if [[ "$state" == "open" && "$head" == *haspr* ]]; then
        (( want_url )) && echo "https://github.com/demo/x/pull/99" || echo "99"
        exit 0
    fi
    if [[ "$state" == "merged" && "$head" == *wasmerged* ]]; then
        echo "98"; exit 0
    fi
    exit 0
fi

exit 0
