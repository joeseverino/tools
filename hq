#!/usr/bin/env bash
# hq — sync vault frontmatter to Severino HQ, and a few quality-of-life ops.
#
# Every `ssh "$HQ_SSH_HOST" "<remote command>"` call in this file deliberately
# expands $HQ_REMOTE_PATH on the client side — the remote shell needs the
# resolved literal path, not the env var. SC2029 flags this pattern as
# potentially ambiguous; here it's intentional.
# shellcheck disable=SC2029

set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" hq

LIB_DIR="$TOOLS_HOME/lib"

usage() {
    cat <<EOF
Usage: hq <command> [args]

Severino HQ glue. Reads YAML frontmatter from the vault and upserts the
HQ docs index. Also wraps the routine ssh + docker compose calls for
managing the HQ deployment.

Commands:
  manifest             Print the manifest JSON (frontmatter from every doc)
                       to stdout. Useful for inspection or piping elsewhere.

  sync [--prune]       Pipe the manifest into HQ's manage.py import_docs_manifest
                       on $HQ_SSH_HOST. Upserts by doc_id; safe to re-run.
                       --prune deletes orphan rows (after a doc_id rename)
                       and stale mirrored ContentItems tied only to those rows.

  doctor               Report vault docs that are missing or have invalid
                       frontmatter — the gap between vault state and HQ state.

  validate             Report HQ registry entries (Projects/Assets) that no
                       vault doc references — the inverse of \`sync\`'s missing
                       relations. Catches stale slugs left by a rename and
                       duplicate registry rows. Read-only.

  create <kind> <slug> [flags]
                       Create or update a Project or Asset in HQ.
                       \`hq create project --help\` / \`hq create asset --help\`
                       for the full flag list. Idempotent (upserts by slug).

  deploy [--no-build]  git pull on $HQ_SSH_HOST and \`docker compose up -d --build\`.
                       --no-build skips the rebuild (use when only env/data changed,
                       not for code changes — image must be rebuilt for new code).

  ship -m MESSAGE [--no-sync]
                       Commit + push local HQ changes, deploy, run remote
                       Django checks, then hq sync. The common "small HQ fix"
                       path in one command.

  logs [-f] [--tail N] Show app container logs. Default tail is 50.
                       -f / --follow streams live output until Ctrl-C.

  restart              \`docker compose restart app\` — no rebuild, no migrations.
                       Use for picking up env changes or clearing stuck state.

  open                 Open \$HQ_URL in the browser.

  shell                ssh -t into the HQ Django shell. Handy for poking the ORM.

  superuser            ssh -t into HQ and run createsuperuser interactively.

  export <year> [md|json]
                       Download the year summary (.md or .json) to ./ and print
                       the path. Defaults to current year and md.

Env (read from ~/.zshrc unless overridden per-invocation):
  NOTES_HOME           Vault root (= $NOTES_HOME)
  HQ_VAULT_DIRS        Colon-separated subdirs to index (= $HQ_VAULT_DIRS)
  HQ_SSH_HOST          SSH alias of the HQ server (= $HQ_SSH_HOST)
  HQ_REMOTE_PATH       HQ checkout path on the server (= $HQ_REMOTE_PATH)
  HQ_LOCAL_PATH        Local HQ checkout (= $HQ_LOCAL_PATH)
  HQ_URL               Public URL of HQ (= $HQ_URL)

Examples:
  hq sync                       # most common — push vault → HQ
  hq manifest | jq '.[] | .doc_id'
  hq doctor                     # find docs missing frontmatter
  hq export 2026                # download year-summary-2026.md
EOF
}

cmd_manifest() {
    python3 "$LIB_DIR/hq-manifest.py" "$VAULT" "$HQ_VAULT_DIRS"
}

cmd_sync() {
    local extra_flags=""
    local prune="0"
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --prune) extra_flags="$extra_flags --prune"; prune="1"; shift ;;
            --no-update) extra_flags="$extra_flags --no-update"; shift ;;
            -h|--help)
                cat <<HELP
Usage: hq sync [--prune] [--no-update]

Walk the vault, build a manifest, push it to HQ. Upserts DocumentationRecord
rows by doc_id (and ContentItem rows for site CMS docs by slug). Re-runs
are idempotent.

  --prune       Delete orphan DocumentationRecord rows (doc_ids in HQ but
                not in the current manifest). Use after a doc_id rename or
                a doc retirement. Mirrored ContentItems that are only linked
                to pruned docs are removed with them.
  --no-update   Only create new records; never update existing ones.

Without flags, sync reports orphans but doesn't delete them.
HELP
                return 0 ;;
            *) die "unknown flag: $1 (try \`hq sync --help\`)" ;;
        esac
    done

    local tmp
    tmp="$(mktemp -t hq-manifest.XXXXXX.json)"
    trap 'rm -f "${tmp:-}"' EXIT

    python3 "$LIB_DIR/hq-manifest.py" "$VAULT" "$HQ_VAULT_DIRS" > "$tmp" 2>/dev/null

    msg "$DIM" "sync" "vault → HQ"
    local stats_json
    stats_json="$(
        ssh "$HQ_SSH_HOST" \
            "cd '$HQ_REMOTE_PATH' && sudo docker compose exec -T app python manage.py import_docs_manifest --json --report-orphans$extra_flags -" \
            < "$tmp"
    )"

    python3 - "$tmp" "$stats_json" "$prune" <<'PY'
import json
import sys

manifest_path, raw_stats, prune_flag = sys.argv[1], sys.argv[2], sys.argv[3]
manifest = json.load(open(manifest_path, encoding="utf-8"))
stats = json.loads(raw_stats)
prune = prune_flag == "1"

created = stats.get("created", 0)
updated = stats.get("updated", 0)
doc_pruned = stats.get("orphans_pruned", 0)
content_synced = stats.get("content_items_synced", 0)
content_pruned = stats.get("content_items_pruned", 0)
missing = stats.get("missing_relations", 0)
orphans = stats.get("orphans") or []

print(f"Docs      {len(manifest)} indexed")

changes = []
if created:
    changes.append(f"{created} created")
if updated:
    changes.append(f"{updated} updated")
if doc_pruned:
    changes.append(f"{doc_pruned} removed")
print(f"Changes   {', '.join(changes) if changes else 'none'}")

if missing:
    print(f"Relations {missing} missing")
    for item in stats.get("missing_relations_detail", [])[:8]:
        print(f"          {item['doc_id']} → missing {item['kind']} {item['slug']}")
else:
    print("Relations ok")

content = []
if content_synced:
    content.append(f"{content_synced} mirrored")
if content_pruned:
    content.append(f"{content_pruned} stale removed")
print(f"Content   {', '.join(content) if content else 'none'}")

if orphans:
    if prune:
        print(f"Cleanup   pruned {len(orphans)} orphan doc row(s)")
    else:
        print(f"Cleanup   {len(orphans)} orphan doc row(s); run `hq sync --prune`")
        for doc_id in orphans[:8]:
            print(f"          {doc_id}")
else:
    print("Cleanup   no orphans")

if missing or (orphans and not prune):
    print("Done      synced with cleanup needed")
else:
    print("Done      HQ is in sync")
PY
}

cmd_doctor() {
    python3 - "$VAULT" "$HQ_VAULT_DIRS" <<'PY'
import sys
from pathlib import Path

vault = Path(sys.argv[1])
subdirs = [s for s in sys.argv[2].split(":") if s]
problems = []
skip_dirs = {".git", ".obsidian", "00 Templates", "Templates", "source"}

# The manifest generator synthesizes stable fallback doc_ids for slim
# site-CMS files under these directories: writeup-<slug> and page-<slug>.
slim_contract_dirs = {"05 Writeups", "06 Pages"}

def should_skip(path: Path) -> bool:
    return any(part in skip_dirs for part in path.parts)

for sub in subdirs:
    root = vault / sub
    if not root.is_dir():
        continue
    for path in sorted(root.rglob("*.md")):
        if should_skip(path):
            continue
        if path.name.startswith("_"):
            continue
        text = path.read_text(encoding="utf-8", errors="replace")
        if not text.lstrip().startswith("---"):
            problems.append((path, "no frontmatter"))
            continue
        if "doc_id:" not in text.split("---", 2)[1]:
            relative = path.relative_to(vault)
            top = relative.parts[0] if relative.parts else ""
            if top in slim_contract_dirs and path.name == "index.md":
                continue
            problems.append((path, "missing doc_id"))

if not problems:
    print("ok: every indexed doc has valid frontmatter")
    sys.exit(0)

print(f"{len(problems)} doc(s) need attention:")
for p, why in problems:
    print(f"  - [{why}] {p.relative_to(vault)}")
sys.exit(1)
PY
}

cmd_validate() {
    case "${1:-}" in
        -h|--help)
            cat <<HELP
Usage: hq validate

Read-only audit of the HQ Project/Asset registries against the docs that
reference them. \`hq sync\` already reports vault relations that point at a
missing registry slug; this reports the *inverse* — registry rows that no
doc references (zero documentation_records).

A zero-doc row is not always wrong (a freshly registered project may not have
a doc yet), but it is the fingerprint of a rename that left a stale slug or a
duplicate row (e.g. the 2026-06-04 jseverino-public-site dedup). Review each.
HELP
            return 0 ;;
    esac

    msg "$DIM" "validate" "HQ registry ↔ vault docs"
    ssh "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose exec -T app python manage.py shell" <<'PY'
from projects.models import Project
from assets.models import Asset

orphan_p = sorted(p.slug for p in Project.objects.all() if p.documentation_records.count() == 0)
orphan_a = sorted(a.slug for a in Asset.objects.all() if a.documentation_records.count() == 0)

print("Projects  %d total, %d with zero docs" % (Project.objects.count(), len(orphan_p)))
for s in orphan_p:
    print("          orphan: %s" % s)
print("Assets    %d total, %d with zero docs" % (Asset.objects.count(), len(orphan_a)))
for s in orphan_a:
    print("          orphan: %s" % s)
if orphan_p or orphan_a:
    print("Registry  review orphans above — stale slug from a rename, or a duplicate row")
else:
    print("Registry  ok — every Project and Asset is referenced by at least one doc")
PY
}

cmd_create() {
    local kind="${1:-}"
    local mgmt=""
    case "$kind" in
        project) shift; mgmt="create_project" ;;
        asset)   shift; mgmt="create_asset" ;;
        ""|-h|--help|help)
            cat <<HELP
Usage: hq create project <slug> --name "<name>" [flags]
       hq create asset   <slug> --name "<name>" [flags]

Common Project flags:
  --name TEXT           (required) Display name
  --category CHOICE     wordpress_security | cloudflare | dns_email_security |
                        homelab | vps | tailscale | adguard | networking |
                        tls_certificates | automation | cybersecurity_labs | other
  --status CHOICE       idea | active | paused | completed | published | archived
  --description TEXT
  --technologies TEXT   Comma-separated
  --repo URL
  --url URL             Public-facing URL
  --notes TEXT

Common Asset flags:
  --name TEXT           (required) Display name
  --category CHOICE     networking | server_hardware | software | subscription |
                        domain | hosting | camera_audio | office | tools |
                        training | other
  --status CHOICE       active | retired | sold | returned | replaced
  --vendor TEXT
  --purchase-date YYYY-MM-DD
  --cost DECIMAL
  --business-use INT    0-100 (default 100)
  --payment CHOICE      cash | debit | credit | ach | paypal | other
  --serial TEXT
  --warranty-date YYYY-MM-DD
  --notes TEXT

Examples:
  hq create project my-site --name "My Site" \\
      --category cloudflare --status published \\
      --repo https://github.com/you/your-repo \\
      --url https://example.com

  hq create asset example-com --name "example.com" --category domain
HELP
            return 0 ;;
        *) die "unknown kind: $kind (use 'project' or 'asset')" ;;
    esac

    [ "$#" -ge 1 ] || die "missing <slug>; try \`hq create $kind --help\`"

    local remote_cmd="cd '$HQ_REMOTE_PATH' && sudo docker compose exec -T app python manage.py $mgmt"
    local arg
    for arg in "$@"; do
        remote_cmd+=" $(printf '%q' "$arg")"
    done

    msg "$DIM" "hq" "$mgmt $1"
    ssh "$HQ_SSH_HOST" "$remote_cmd"
}

cmd_deploy() {
    local build_flag="--build"
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --no-build) build_flag=""; shift ;;
            -h|--help)
                cat <<HELP
Usage: hq deploy [--no-build]

git pull on $HQ_SSH_HOST then \`docker compose up -d --build\`. The container
entrypoint reruns migrate + collectstatic on every boot.

  --no-build   Skip the image rebuild. Only safe when no source files
               changed (e.g. you just edited the .env on the server).
HELP
                return 0 ;;
            *) die "unknown flag: $1 (try \`hq deploy --help\`)" ;;
        esac
    done

    msg "$DIM" "deploying" "$HQ_SSH_HOST:$HQ_REMOTE_PATH"
    ssh "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && git pull --ff-only && sudo docker compose up -d $build_flag"
    msg "$GREEN" "deployed" "severino-hq"
}

cmd_ship() {
    local message=""
    local no_sync=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            -m|--message) message="${2:?--message needs text}"; shift 2 ;;
            --message=*) message="${1#--message=}"; shift ;;
            --no-sync) no_sync="1"; shift ;;
            -h|--help)
                cat <<HELP
Usage: hq ship -m "commit message" [--no-sync]

One-command path for small HQ corrections:

  1. Run lightweight local Python syntax checks.
  2. Commit tracked/known HQ repo changes.
  3. Push the HQ repo.
  4. Deploy HQ on $HQ_SSH_HOST.
  5. Run remote \`manage.py check\`.
  6. Run \`hq sync\` unless --no-sync is set.

Only files already tracked by git plus new files under known app directories are
staged. Local scratch like .claude/ is ignored.

  -m, --message TEXT   Commit message for HQ repo changes.
  --no-sync            Skip the final vault → HQ manifest sync.
HELP
                return 0 ;;
            *) die "unknown flag: $1 (try \`hq ship --help\`)" ;;
        esac
    done

    [[ -n "$message" ]] || die "usage" "missing -m \"commit message\""
    [[ -d "$HQ_LOCAL_PATH/.git" ]] || die "error" "HQ_LOCAL_PATH is not a git repo: $HQ_LOCAL_PATH"

    msg "$DIM" "checking" "$HQ_LOCAL_PATH"
    (
        cd "$HQ_LOCAL_PATH"
        git ls-files '*.py' | xargs python3 -m py_compile
    )

    local before
    before="$(git -C "$HQ_LOCAL_PATH" status --porcelain)"
    if [[ -n "$before" ]]; then
        msg "$DIM" "staging" "tracked changes + known HQ app files"
        (
            cd "$HQ_LOCAL_PATH"
            git add -u
            git add \
                assets content core docs docs_index expenses projects receipts reports \
                static templates \
                2>/dev/null || true
        )

        if git -C "$HQ_LOCAL_PATH" diff --cached --quiet; then
            msg "$YELLOW" "skipped" "no committable HQ changes staged"
        else
            git -C "$HQ_LOCAL_PATH" commit -m "$message"
            git -C "$HQ_LOCAL_PATH" push
        fi
    else
        msg "$GREEN" "clean" "no local HQ changes to commit"
    fi

    cmd_deploy

    msg "$DIM" "checking" "remote Django system check"
    ssh "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose exec -T app python manage.py check"

    if [[ -z "$no_sync" ]]; then
        cmd_sync
    else
        msg "$YELLOW" "sync" "skipped (--no-sync)"
    fi

    if [[ -n "$(git -C "$VAULT" status --porcelain 2>/dev/null || true)" ]]; then
        msg "$YELLOW" "vault" "has uncommitted changes; run vault status/sync when ready"
    fi

    msg "$GREEN" "shipped" "HQ correction complete"
}

cmd_logs() {
    local tail="50"
    local follow=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            -f|--follow) follow="-f"; shift ;;
            --tail) tail="${2:?--tail needs a number}"; shift 2 ;;
            --tail=*) tail="${1#--tail=}"; shift ;;
            -h|--help)
                cat <<HELP
Usage: hq logs [-f|--follow] [--tail N]

Show the severino-hq app container logs.

  -f, --follow   Stream live until Ctrl-C.
  --tail N       Number of lines to show (default 50). Ignored with --follow
                 — Docker's follow streams from "now" by design.
HELP
                return 0 ;;
            *) die "unknown flag: $1 (try \`hq logs --help\`)" ;;
        esac
    done

    if [ -n "$follow" ]; then
        ssh -t "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose logs app -f"
    else
        ssh "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose logs app --tail $tail"
    fi
}

cmd_restart() {
    msg "$DIM" "restarting" "severino-hq"
    ssh "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose restart app"
    msg "$GREEN" "restarted" "severino-hq"
}

cmd_open() {
    if command -v open >/dev/null 2>&1; then
        open "$HQ_URL"
    else
        msg "$DIM" "open" "$HQ_URL"
    fi
}

cmd_shell() {
    ssh -t "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose exec app python manage.py shell"
}

cmd_superuser() {
    ssh -t "$HQ_SSH_HOST" "cd '$HQ_REMOTE_PATH' && sudo docker compose exec app python manage.py createsuperuser"
}

cmd_export() {
    local year="${1:-$(date +%Y)}"
    local fmt="${2:-md}"
    case "$fmt" in
        md|markdown) ext="md"; route="year-summary.md" ;;
        json) ext="json"; route="year-summary.json" ;;
        *) die "unknown format: $fmt (use md or json)" ;;
    esac
    local out="year-summary-$year.$ext"
    msg "$DIM" "fetching" "$HQ_URL/reports/export/$route?year=$year"
    # Use curl with the system's resolver — Tailscale + AdGuard handle DNS.
    # The endpoint requires auth; this expects /tmp/hq-cookies.txt to exist
    # from a prior browser sign-in via `tailscale + browser`. If absent, run
    # `hq open` and sign in, then re-export.
    curl -fsSL --cookie-jar /tmp/hq-cookies.txt --cookie /tmp/hq-cookies.txt \
        "$HQ_URL/reports/export/$route?year=$year" -o "$out"
    msg "$GREEN" "wrote" "$out"
    printf '%s\n' "$out"
}

case "${1:-}" in
    ""|-h|--help|help) usage; exit 0 ;;
    manifest)   shift; cmd_manifest "$@" ;;
    sync)       shift; cmd_sync "$@" ;;
    doctor)     shift; cmd_doctor "$@" ;;
    validate)   shift; cmd_validate "$@" ;;
    create)     shift; cmd_create "$@" ;;
    deploy)     shift; cmd_deploy "$@" ;;
    ship)       shift; cmd_ship "$@" ;;
    logs)       shift; cmd_logs "$@" ;;
    restart)    shift; cmd_restart "$@" ;;
    open)       shift; cmd_open "$@" ;;
    shell)      shift; cmd_shell "$@" ;;
    superuser)  shift; cmd_superuser "$@" ;;
    export)     shift; cmd_export "$@" ;;
    *) die "unknown command: $1 (try \`hq --help\`)" ;;
esac
