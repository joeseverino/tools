# shellcheck shell=bash
# site.sh — optional local overrides for the public Astro site workflow.
#
# Copy to config/site.sh and edit if your layout differs from the defaults.
# The real config/site.sh is gitignored.

CODE_HOME="${CODE_HOME:-$HOME/Documents/Code}"
SITE_HOME="${SITE_HOME:-$CODE_HOME/Projects/jseverino.com}"
SITE_DEV_HOST="${SITE_DEV_HOST:-127.0.0.1}"
SITE_DEV_PORT="${SITE_DEV_PORT:-4321}"
SITE_LIVE_URL="${SITE_LIVE_URL:-https://jseverino.com}"
SITE_COMPARE_HOST="${SITE_COMPARE_HOST:-127.0.0.1}"
SITE_COMPARE_PORT="${SITE_COMPARE_PORT:-4178}"
SITE_COMPARE_NAME="${SITE_COMPARE_NAME:-compare.homelab}"
# Defaults to the cert-gen output for compare.homelab.
# SITE_COMPARE_CERT_DIR="$HOME/Documents/Code/Assets/PKI/Issued Certificates/compare.homelab"
SITE_COMPARE_BROWSER="${SITE_COMPARE_BROWSER:-Safari}"
