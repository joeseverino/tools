#!/usr/bin/env bash
# decrypt <file.age>... — age-decrypt with your private key, restore original
set -euo pipefail

source "${TOOLS_HOME:?set in ~/.zshrc}/lib/init.sh" crypt
source "$TOOLS_HOME/lib/key.sh"

usage() {
    cat <<EOF
Usage: decrypt [options] <file.age>...

Decrypts .age files using your default age private key. If the key is an
SSH key with a passphrase, decrypt unlocks it transparently using the
passphrase cached via 'tools key cache' — one prompt up front, silent
forever after. With no cached passphrase, it prompts (terminal or
osascript dialog, whichever is appropriate).

Options:
  -f, --force         Overwrite existing decrypted output files
  -k, --key <path>    Add another identity to try (repeatable). Bypasses
                      the cached passphrase / unlock path for that key.
  -p, --stdout        Write decrypted bytes to stdout, not to a file.
                      Silent on success; status/errors go to stderr.
                      Useful for piping or one-off viewing without leaving
                      plaintext on disk: decrypt -p secret.age | less
      --no-cache      Don't use the cached passphrase even if one exists.
                      Lets age prompt directly (terminal only).
  -h, --help          Show this help

Environment:
  KEYS_HOME           Read from ~/.zshrc; resolves AGE_KEY
  AGE_KEY             Per-invocation override for the private key path

Examples:
  decrypt notes.md.age
  decrypt -k ~/keys/oldkey notes.md.age
  decrypt -f *.age
  decrypt -p secret.age | less
EOF
}

FORCE=0
STDOUT=0
NO_CACHE=0
EXTRA_KEYS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)   usage; exit 0 ;;
        -f|--force)  FORCE=1; shift ;;
        -p|--stdout) STDOUT=1; shift ;;
        --no-cache)  NO_CACHE=1; shift ;;
        -k|--key)
            [[ -n "${2:-}" ]] || die "usage" "-k requires a key path" 2
            EXTRA_KEYS+=("$2"); shift 2 ;;
        --)          shift; break ;;
        -*)          die "usage" "unknown option: $1 (try -h)" 2 ;;
        *)           break ;;
    esac
done

[[ $# -ge 1 ]] || die "usage" "decrypt <file.age>... (try -h)" 2
command -v age >/dev/null || die "error" "age not installed (brew install age)"
[[ -f "$AGE_KEY" ]] || die "error" "no default private key at: $AGE_KEY"
if (( ${#EXTRA_KEYS[@]} > 0 )); then
    for k in "${EXTRA_KEYS[@]}"; do
        [[ -f "$k" ]] || die "error" "additional key not found: $k"
    done
fi

cleanup_unlocked() {
    [[ -n "$UNLOCKED_KEY" && -f "$UNLOCKED_KEY" ]] && rm -f "$UNLOCKED_KEY"
}
trap cleanup_unlocked EXIT INT TERM

if (( STDOUT )); then
    exec 3>&1
    exec 1>&2
fi

# One prompt (if needed) for the whole batch.
if ! unlock_age_key "${NO_CACHE:+1}"; then
    case $? in
        1) die "error" "no passphrase provided" ;;
        2) die "error" "wrong passphrase for $AGE_KEY (try: tools key cache)" ;;
        3) die "error" "no private key at: $AGE_KEY" ;;
        *) die "error" "could not unlock $AGE_KEY" ;;
    esac
fi
identities=("-i" "$AGE_IDENTITY")
if (( ${#EXTRA_KEYS[@]} > 0 )); then
    for k in "${EXTRA_KEYS[@]}"; do
        identities+=("-i" "$k")
    done
fi

ok=0; failed=0; skipped=0
(( STDOUT )) || header "decrypting" "$#"

for f in "$@"; do
    if [[ ! -f "$f" ]]; then
        msg "$YELLOW" "skipped" "$f ${DIM}(not a file)${RESET}"
        skipped=$((skipped+1))
        continue
    fi
    if [[ "$f" != *.age ]]; then
        msg "$YELLOW" "skipped" "$f ${DIM}(not a .age file)${RESET}"
        skipped=$((skipped+1))
        continue
    fi
    if (( STDOUT )); then
        if err=$(age -d "${identities[@]}" "$f" 2>&1 >&3); then
            ok=$((ok+1))
        else
            msg "$RED" "failed" "$f ${DIM}($(age_reason "$err"))${RESET}"
            failed=$((failed+1))
        fi
        continue
    fi
    out="${f%.age}"
    if [[ -e "$out" && $FORCE -eq 0 ]]; then
        msg "$YELLOW" "skipped" "$f ${DIM}($out exists, -f to overwrite)${RESET}"
        skipped=$((skipped+1))
        continue
    fi
    if err=$(age -d "${identities[@]}" -o "$out" "$f" 2>&1); then
        msg "$GREEN" "decrypted" "$f ${DIM}→${RESET} $out"
        ok=$((ok+1))
    else
        msg "$RED" "failed" "$f ${DIM}($(age_reason "$err"))${RESET}"
        failed=$((failed+1))
    fi
done

(( STDOUT )) || footer "decrypted" "$ok" "$skipped" "$failed"
(( failed == 0 ))
